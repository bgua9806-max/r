 */
function findRowByBookingId_(sheet, bookingId) {
  if (!bookingId) return 0;
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return 0;

  var target = bookingId.toString().trim();
  var values = sheet.getRange(2, 4, lastRow - 1, 1).getValues(); // Cột D: Mã BK
  for (var i = 0; i < values.length; i++) {
    if (values[i][0] && values[i][0].toString().trim() === target) {
      return i + 2;
    }
  }
  return 0;
}

/**
 * Cập nhật tất cả dòng cùng Mã BK trong sheet test/chính.
 * Dùng cho booking Trip.com đã tách thành nhiều dòng theo từng ngày.
 */
function updateAllRowsByBookingId_(sheet, bookingId, statusValue, cancelDate, noteValue) {
  if (!bookingId) return 0;
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return 0;

  var target = bookingId.toString().trim();
  var values = sheet.getRange(2, 4, lastRow - 1, 1).getValues(); // D: Mã BK
  var updatedCount = 0;

  for (var i = 0; i < values.length; i++) {
    var currentId = values[i][0] ? values[i][0].toString().trim() : "";
    if (currentId === target) {
      var rowIndex = i + 2;
      sheet.getRange(rowIndex, 19).setValue(statusValue || "CANCEL"); // S
      sheet.getRange(rowIndex, 21).setValue(cancelDate || "");        // U: DATE CANCELLED
      if (noteValue) sheet.getRange(rowIndex, 18).setValue(noteValue); // R
      updatedCount++;
    }
  }

  return updatedCount;
}


