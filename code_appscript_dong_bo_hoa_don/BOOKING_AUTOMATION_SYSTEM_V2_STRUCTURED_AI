            syncBookingToSupabase_(testBookingData, ss);
          }
        }
        paintDuplicateBookingRows_(resultSheet);

      } catch (e) {
        resultSheet.appendRow([
          message.getDate(), "", "", "", "", "", "", "", "", "",
