/**
 * ✅ V25: Build Gmail Search Query từ config
 * Xử lý toán tử && → chuyển thành Gmail syntax ("keyword1" "keyword2")
 */
function buildSearchQuery(configs) {
  var parts = [];

  for (var i = 0; i < configs.length; i++) {
    var cfg = configs[i];

    // --- Booking mới ---
    if (cfg.bookingKeyword) {
      var bookingPart = buildSingleQueryPart(cfg.bookingKeyword, cfg.fromEmail);
      parts.push(bookingPart);
    }

    // --- Email hủy ---
    if (cfg.cancelKeyword) {
      var cancelFrom = cfg.cancelFrom || cfg.fromEmail; // Dùng cancelFrom, nếu trống thì dùng fromEmail
      var cancelPart = buildSingleQueryPart(cfg.cancelKeyword, cancelFrom);
      parts.push(cancelPart);
    }
  }

  if (parts.length === 0) return "";

  return "(" + parts.join(" OR ") + ") -subject:Re: newer_than:1d";
}



/**
 * ✅ V25.1: Build 1 phần query cho 1 keyword + from
 * "Agoda Booking ID && CONFIRMED || Xác nhận đặt phòng && Agoda" + "auto@trip.com" 
 *   → (from:auto@trip.com (("Agoda Booking ID" "CONFIRMED") OR ("Xác nhận đặt phòng" "Agoda")))
 */
function buildSingleQueryPart(keyword, fromEmail) {
  var queryParts = [];

  // Thêm from: nếu có
  if (fromEmail) {
    queryParts.push("from:" + fromEmail);
  }

  // Xử lý || (OR) và && (AND)
  var orKeywords = keyword.split("||");
  var orParts = [];
  
  for (var i = 0; i < orKeywords.length; i++) {
    var andKeywords = orKeywords[i].split("&&");
    var andParts = [];
    for (var j = 0; j < andKeywords.length; j++) {
      var kw = andKeywords[j].trim();
      if (kw) andParts.push('"' + kw + '"');
    }
    if (andParts.length > 0) {
      orParts.push("(" + andParts.join(" ") + ")");
    }
  }

  if (orParts.length > 0) {
    queryParts.push("(" + orParts.join(" OR ") + ")");
  }

  return "(" + queryParts.join(" ") + ")";
}



/**
 * ✅ V25: Phát hiện platform từ config (Dynamic)
 * Kiểm tra subject + body có khớp từ khóa booking trong config không
 */
function detectPlatformFromConfig(text, subject, fromEmail, configs) {
  var combined = subject + " " + text + " " + fromEmail;

  for (var i = 0; i < configs.length; i++) {
    var cfg = configs[i];
    if (!cfg.bookingKeyword) continue;

    // Kiểm tra from email (nếu config có chỉ định)
    if (cfg.fromEmail && fromEmail.indexOf(cfg.fromEmail) === -1) {
      continue;
    }

    // Kiểm tra từ khóa (hỗ trợ &&)
    if (matchKeywords(combined, cfg.bookingKeyword)) {
      return cfg.platform;
    }
  }

  // Fallback: dùng hàm cũ
  return detectPlatform(text, subject);
}



/**
 * ✅ V25: Kiểm tra email hủy từ config (Dynamic)
 */
function isCancellationFromConfig(subject, fromEmail, configs) {
  for (var i = 0; i < configs.length; i++) {
    var cfg = configs[i];
    if (!cfg.cancelKeyword) continue; // Platform không hỗ trợ hủy

    // Kiểm tra from email hủy
    var expectedFrom = cfg.cancelFrom || cfg.fromEmail;
    if (expectedFrom && fromEmail.indexOf(expectedFrom) === -1) {
      continue;
    }

    // Kiểm tra từ khóa hủy (hỗ trợ &&)
    if (matchKeywords(subject + " " + fromEmail, cfg.cancelKeyword)) {
      return true;
    }
  }

  // Fallback: dùng hàm cũ
  return isCancellationEmail(subject, fromEmail);
}



/**
 * ✅ V25.1: Kiểm tra text có chứa từ khóa không
 * Hỗ trợ toán tử || (OR) và && (AND)
 * "Keyword A && Keyword B || Keyword C"
 * Ưu tiên && xử lý theo nhóm khối trước, sau đó || đại diện mức kết hợp
 */
function matchKeywords(text, keywordStr) {
  var orGroups = keywordStr.split("||");
  
  for (var i = 0; i < orGroups.length; i++) {
    var andKeywords = orGroups[i].split("&&");
    var matchAllAnd = true;
    
    for (var j = 0; j < andKeywords.length; j++) {
      var kw = andKeywords[j].trim();
      if (kw && text.indexOf(kw) === -1) {
        matchAllAnd = false;
        break;
      }
    }
    
    // Nếu có 1 nhóm OR (||) đúng toàn bộ phần AND (&&), thì coi như text thỏa mãn
    if (matchAllAnd) {
      return true;
    }
  }
  
  return false;
}



