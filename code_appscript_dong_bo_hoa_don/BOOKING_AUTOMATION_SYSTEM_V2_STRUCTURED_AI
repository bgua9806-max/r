/**
 * ✨ V25: Config-Driven - Đọc cấu hình từ Sheet Platform_Config
 * - Tự động build SEARCH_QUERY từ config
 * - Phát hiện platform động (không hardcode)
 * - Hỗ trợ bật/tắt từng platform (ON/OFF)
 */
function mainAutoProcess1() {
  try {
    var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);

    // ═══════════════════════════════════════════════════════════════════
    // ✅ V25: Đọc config từ Sheet + Build Search Query động
    // ═══════════════════════════════════════════════════════════════════
    var platformConfigs = loadPlatformConfig(ss);
    if (platformConfigs.length === 0) {
      logToSheet(ss, "⚠️ Không có platform nào đang ON trong Platform_Config.");
      return;
    }
    var searchQuery = buildSearchQuery(platformConfigs);

    var threads;
    try {
      threads = GmailApp.search(searchQuery, 0, CONFIG.BATCH_SIZE);
    } catch (e) {
      if (e.toString().indexOf("too many times") > -1) return;
      throw e;
    }

    if (threads.length === 0) return; 


    logToSheet(ss, "🚀 Phát hiện " + threads.length + " thread email trong danh sách quét.");


    var sheetData = getOrCreateSheet(ss, CONFIG.SHEET_DATA_NAME);
    var existingIds = getExistingBookingIds(sheetData);
    var processedCount = 0;
    var skippedOldCount = 0;
    var skippedDuplicateCount = 0;
    var cancelledCount = 0;


    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 🔄 VÒNG LẶP THREAD
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    for (var i = 0; i < threads.length; i++) {
      var messages = threads[i].getMessages();

      logToSheet(ss, "📧 Thread #" + (i + 1) + " có " + messages.length + " email. Bắt đầu quét...");


      // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
      // 🔁 VÒNG LẶP EMAIL TRONG THREAD (V25 - DYNAMIC)
      // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
      for (var j = 0; j < messages.length; j++) {
        var message = messages[j];
        var subject = message.getSubject();
        var fromEmail = message.getFrom();

        // 1️⃣ Kiểm tra thời gian
        if (isEmailTooOld(message.getDate(), 30)) { 
          skippedOldCount++;
          continue;
        }


        // ═══════════════════════════════════════════════════════════════════
        // ✅ V25: KIỂM TRA EMAIL HỦY (DYNAMIC từ config)
        // ═══════════════════════════════════════════════════════════════════
        if (isCancellationFromConfig(subject, fromEmail, platformConfigs)) {
          var cancelResult = processCancellationEmail(message, subject, fromEmail, sheetData, ss);
          if (cancelResult) {
            cancelledCount++;
            message.markRead();
            applyGmailLabel(message, CONFIG.LABEL_CANCELLED);

            // ✅ SYNC HỦY LÊN SUPABASE (THAY THẾ N8N)
            var cancelBookingId = quickFindID(getDeepCleanBody(message), subject);
            if (cancelBookingId) {
              syncCancellationToSupabase_(cancelBookingId, new Date().toISOString(), ss);
            }
          }
          continue;
        }


        // ═══════════════════════════════════════════════════════════════════
        // 📋 XỬ LÝ BOOKING MỚI
        // ═══════════════════════════════════════════════════════════════════

        var plainText = getDeepCleanBody(message);


        // 3️⃣ Kiểm tra trùng lặp ID (Fast Check)
        var quickID = quickFindID(plainText, subject);
        if (quickID && existingIds.includes(quickID)) {
          skippedDuplicateCount++;
          continue;
        }


        // 4️⃣ Xử lý chi tiết
        var success = processSingleEmailCore(message, plainText, sheetData, existingIds, ss);
        if (success) processedCount++;
      }
      // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    }
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


    // 📊 BÁO CÁO TỔNG HỢP
    var summaryMessage = "✅ HOÀN THÀNH:\n" +
      "  • Threads quét: " + threads.length + "\n" +
      "  • Booking mới xử lý: " + processedCount + "\n" +
      "  • Booking hủy xử lý: " + cancelledCount + "\n" +
      "  • Email cũ (bỏ qua): " + skippedOldCount + "\n" +
      "  • Email trùng ID (bỏ qua): " + skippedDuplicateCount;

    logToSheet(ss, summaryMessage);

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📂 QUÉT THÊM GOOGLE DRIVE PDF (NẾU CÓ)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    processDriveBookings(sheetData, existingIds, ss);

  } catch (e) {
    Logger.log("CRITICAL ERROR: " + e.toString());
    logToSheet(SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID), "❌ LỖI NGHIÊM TRỌNG: " + e.toString());
  }
}



// ============================================================================
// MODULE 3: BỘ XỬ LÝ TRUNG TÂM (V25 - OVERRIDE TẤT CẢ GIÁ TRỊ REGEX)
// ============================================================================


function processSingleEmailCore(message, plainText, sheet, existingIds, ss) {
  // plainText = nội dung đầy đủ, dùng cho daily rate extraction.
  try {
    // 1. Cắt gọt nội dung thông minh
    var smartContext = getHeadAndTail(plainText);

    // 2. Phân loại Platform
    var platform = detectPlatform(smartContext, message.getSubject());

    // 3. Quét dữ liệu cứng (Đã Fix lỗi Agoda Surcharge)
    var hardData = scanDataByPlatform(smartContext, platform);

    // 4. Gọi AI
    // ✅ V2: Chuyển plain text đã clean sang Markdown có cấu trúc trước khi gửi AI.
    // Có thể tắt nhanh bằng CONFIG.USE_STRUCTURED_AI_INPUT = false để quay về format cũ.
    var aiInput = CONFIG.USE_STRUCTURED_AI_INPUT
      ? buildStructuredAIInput(message, smartContext, hardData, platform)
      : smartContext;

    var finalData = callOpenAI(aiInput, hardData, platform);

    // ═══════════════════════════════════════════════════════════════════
    // ✅ EXPEDIA: Mặc định số lượng phòng luôn = 1
    // ═══════════════════════════════════════════════════════════════════
    if (platform === "Expedia") {
      finalData.rooms = 1;
    }

    // ═══════════════════════════════════════════════════════════════════
    // ✅ AIRBNB: Ngày dạng "Th 2, 4 thg 5" rất dễ bị AI hiểu nhầm.
    // Ưu tiên ngày quét cứng từ email: "Th 2" là thứ, "4 thg 5" mới là ngày/tháng.
    // ═══════════════════════════════════════════════════════════════════
    if (hardData.check_in) {
      finalData.check_in = hardData.check_in;
    }
    if (hardData.check_out) {
      finalData.check_out = hardData.check_out;
    }

    // ═══════════════════════════════════════════════════════════════════
    // ✅ V25: OVERRIDE - Giá trị regex GHI ĐÈ lên AI cho TẤT CẢ platform
    // Nếu scanDataByPlatform quét được giá trị khác "0" → dùng nó thay AI
    // ═══════════════════════════════════════════════════════════════════
    if (hardData.total_price && hardData.total_price !== "0") {
      finalData.total_price = hardData.total_price;
    }
    if (hardData.net_rate && hardData.net_rate !== "0") {
      finalData.net_rate = hardData.net_rate;
    }
    if (hardData.commission && hardData.commission !== "0") {
      finalData.commission = hardData.commission;
    }
    if (hardData.surcharge && hardData.surcharge !== "0") {
      finalData.surcharge = hardData.surcharge;
    }
    if (hardData.other_programs && hardData.other_programs !== "0") {
      finalData.other_programs = hardData.other_programs;
    }
    if (hardData.payment_status) {
      finalData.payment_status = hardData.payment_status;
    }
    if (hardData.has_breakfast) {
      finalData.breakfast = hardData.has_breakfast;
    }
    
    // ═══════════════════════════════════════════════════════════════════
    // ✅ V23.1: TRIP.COM - Chuẩn hóa tên khách (xóa dấu "/" giữa họ và tên)
    // VD: "HOANG/Thi Lan Phuong" → "HOANG Thi Lan Phuong"
    // ═══════════════════════════════════════════════════════════════════
    if (platform === "Trip.com" && finalData && finalData.guest_name) {
      finalData.guest_name = finalData.guest_name.replace(/\//g, " ").replace(/\s+/g, " ").trim();
    }

    // ═══════════════════════════════════════════════════════════════════
    // ✅ LÀM SẠCH SỐ TIỀN: Loại bỏ dấu phẩy và dấu chấm trước khi ghi vào sheet
    // ═══════════════════════════════════════════════════════════════════
    if (finalData) {
      finalData.total_price = cleanMoneyString(finalData.total_price);
      finalData.net_rate = cleanMoneyString(finalData.net_rate);
      finalData.commission = cleanMoneyString(finalData.commission);
      finalData.surcharge = cleanMoneyString(finalData.surcharge);
      finalData.other_programs = cleanMoneyString(finalData.other_programs);
    }

    // ═══════════════════════════════════════════════════════════════════
    // ✅ V26: FORMAT LẠI TÊN PHÒNG -> (MÃ PHÒNG (xSỐ LƯỢNG)) Ngoại trừ Traveloka
    // ═══════════════════════════════════════════════════════════════════
    var finalRoomType = finalData.room_type;
    
    if (platform !== "Traveloka" && finalRoomType) {
      // Tìm mã phòng:
      // 1: Dạng chuẩn 1G1M8, 2G 1M2, 2G1M6, v.v. (Có số và chữ G, M)
      // 2: Dạng đặc biệt toàn chữ (Ví dụ: GLGN) thường nằm cuối tên phòng hoặc trong ngoặc
      var roomCodeMatch = finalRoomType.match(/(\d+G\s*\d+M\d+)/i); // Kiểm tra dạng 1G1M8 trước
      if (!roomCodeMatch) {
         roomCodeMatch = finalRoomType.match(/\(([A-Z0-9]{3,})\)/i); // Kiểm tra dạng (GLGN), (STD) v.v.
      }
      
      if (roomCodeMatch) {
        // Xóa khoảng trắng trong mã (VD: "2G 1M2" -> "2G1M2")
        var roomCode = roomCodeMatch[1].replace(/\s+/g, '').toUpperCase();
        var roomQty = finalData.rooms || 1;
        finalRoomType = roomCode + ' (x' + roomQty + ')';
      }
    }

    // 5. Kiểm tra và Ghi
    if (finalData && finalData.booking_id) {
      var currentId = finalData.booking_id.toString().trim();

      if (existingIds.includes(currentId) && !(platform === "Trip.com" && CONFIG.SPLIT_TRIPCOM_BY_DAILY_RATE)) {
        logToSheet(ss, "⚠️ Bỏ qua ID trùng (AI Check): " + currentId);
      } else {
        var rowsWritten = writeBookingRowsToSheet_(sheet, message, finalData, finalRoomType, platform, plainText, existingIds, "SUCCESS");

        if (rowsWritten > 0) {
          existingIds.push(currentId);
          logToSheet(ss, "✅ Đã lưu: " + currentId + " (" + finalData.platform + ") - " + rowsWritten + " dòng");

          // ✅ SYNC TRỰC TIẾP LÊN SUPABASE (THAY THẾ N8N)
          syncBookingToSupabase_(finalData, ss);

          message.markRead();
          applyGmailLabel(message, CONFIG.LABEL_PROCESSED);
          return true;
        } else {
          logToSheet(ss, "⚠️ Bỏ qua vì trùng toàn bộ dòng ngày: " + currentId);
        }
      }
    } else {
      message.markRead();
    }
  } catch (e) {
    logToSheet(ss, "❌ Lỗi xử lý email: " + e.toString());
  }
  return false;
}




// ============================================================================
// MODULE 3.5: DAILY RATE SPLIT - TRIP.COM TRƯỚC
// ============================================================================

function writeBookingRowsToSheet_(sheet, message, finalData, finalRoomType, platform, cleanText, existingIds, statusValue) {
  var rows = buildBookingRowsByPlatform_(message, finalData, finalRoomType, platform, cleanText, statusValue || "SUCCESS");
  var written = 0;

  for (var i = 0; i < rows.length; i++) {
    var row = rows[i];
    var bookingId = row[3] ? row[3].toString().trim() : "";
    var checkInKey = formatDateKey_(row[5]);
    var compositeKey = bookingId + "__" + checkInKey;

    // Với row daily, chống trùng theo booking_id + ngày check-in.
    // Với row tổng, checkInKey vẫn là ngày check-in tổng nên vẫn an toàn.
    if (bookingId && hasBookingDateKey_(sheet, compositeKey)) {
      continue;
    }

    sheet.appendRow(row);
    written++;
  }

  if (written > 0) {
    paintDuplicateBookingRows_(sheet);
  }

  return written;
}

function buildBookingRowsByPlatform_(message, finalData, finalRoomType, platform, cleanText, statusValue) {
  if (platform === "Trip.com" && CONFIG.SPLIT_TRIPCOM_BY_DAILY_RATE) {
    var dailyRates = extractTripComDailyRates(cleanText, finalData);
    if (dailyRates && dailyRates.length > 0) {
      var rows = [];
      for (var i = 0; i < dailyRates.length; i++) {
        rows.push(buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, dailyRates[i]));
      }
      return rows;
    }
  }

  if (platform === "Agoda" && CONFIG.SPLIT_AGODA_BY_DAILY_RATE) {
    var agodaDailyRates = extractAgodaDailyRates(cleanText, finalData);
    if (agodaDailyRates && agodaDailyRates.length > 0) {
      var rows = [];
      for (var i = 0; i < agodaDailyRates.length; i++) {
        rows.push(buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, agodaDailyRates[i]));
      }
      return rows;
    }
  }

  if (platform === "Expedia" && CONFIG.SPLIT_EXPEDIA_BY_DAILY_RATE) {
    var expediaDailyRates = extractExpediaDailyRates(cleanText, finalData);
    if (expediaDailyRates && expediaDailyRates.length > 0) {
      var rows = [];
      for (var i = 0; i < expediaDailyRates.length; i++) {
        rows.push(buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, expediaDailyRates[i]));
      }
      return rows;
    }
  }

  if (platform === "Traveloka" && CONFIG.SPLIT_TRAVELOKA_BY_DAILY_RATE) {
    var travelokaDailyRates = extractTravelokaDailyRates(cleanText, finalData);
    if (travelokaDailyRates && travelokaDailyRates.length > 0) {
      var rows = [];
      for (var i = 0; i < travelokaDailyRates.length; i++) {
        rows.push(buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, travelokaDailyRates[i]));
      }
      return rows;
    }
  }

  if (platform === "Airbnb" && CONFIG.SPLIT_AIRBNB_BY_DAILY_RATE) {
    var airbnbDailyRates = extractAirbnbDailyRates(cleanText, finalData);
    if (airbnbDailyRates && airbnbDailyRates.length > 0) {
      var rows = [];
      for (var i = 0; i < airbnbDailyRates.length; i++) {
        rows.push(buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, airbnbDailyRates[i]));
      }
      return rows;
    }
  }

  // Fallback: giữ nguyên 1 dòng tổng như cơ chế cũ.
  return [buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, null)];
}

function buildBookingSheetRow_(message, finalData, finalRoomType, statusValue, dailyRate) {
  var checkInDate = dailyRate ? dailyRate.check_in : parseDateToSheetFormat(finalData.check_in);
  var checkOutDate = dailyRate ? dailyRate.check_out : parseDateToSheetFormat(finalData.check_out);

  return [
    message.getDate(),
    finalData.platform,
    finalData.hotel_name,
    finalData.booking_id,
    finalData.guest_name,
    checkInDate,
    checkOutDate,
    finalRoomType,
    finalData.rooms,
    finalData.occupancy,
    dailyRate ? cleanMoneyString(dailyRate.gross) : finalData.total_price,
    dailyRate ? cleanMoneyString(dailyRate.commission) : finalData.commission,
    dailyRate ? cleanMoneyString(dailyRate.surcharge || finalData.surcharge) : finalData.surcharge,
    dailyRate ? cleanMoneyString(dailyRate.other_programs || finalData.other_programs) : finalData.other_programs,
    dailyRate ? cleanMoneyString(dailyRate.net_rate) : finalData.net_rate,
    finalData.breakfast,
    finalData.payment_status,
    finalData.special_requests,
    statusValue || "SUCCESS",
    "",
    ""
  ];
}

/**
 * Trip.com daily rates parser.
 * Email Trip.com gốc là HTML tiếng Anh. Sau khi getDeepCleanBody() convert,
 * các block daily rate có dạng:
 *   Jun 14 (1 room(s))
 *   Original room rate (incl. taxes and fees) 964706.00*1
 *   Discounts -405177.00*1
 *   Final room rate (incl. taxes and fees) 559529.00*1
 *   Your payout 559529.00*1
 *
 * Hoặc phiên bản tiếng Việt (fallback):
 *   Ngày 14 tháng 6 (1 phòng)
 *   Giá phòng ban đầu ... 964706.00*1
 *   Khoản thanh toán của bạn 559529.00*1
 */
function normalizeBookingComPdfToMarkdown_(rawText, fileName) {
  var text = rawText || "";
  var lines = text.split(/\r?\n/).map(function(line) { return (line || '').trim(); }).filter(function(line) { return line; });
  var md = [];
  var bookingId = (text.match(/Booking\s*number:?\s*(\d+)/i) || text.match(/(?:mã|ma)\s*(?:đặt|dat)?\s*(?:phòng|phong|booking)?\s*:?\s*(\d{6,})/i) || [null, ''])[1];
  var guest = extractBookingComValueAfterLabel_(lines, /Guest information|Thông tin khách/i);
  var totalGuests = extractBookingComValueAfterLabel_(lines, /Total guests|Tổng số khách/i);
  var rooms = extractBookingComValueAfterLabel_(lines, /Total units\/rooms|Tổng số phòng|Tổng số căn/i);
  var checkIn = extractBookingComValueAfterLabel_(lines, /Check-?in|Nhận phòng/i);
  var checkOut = extractBookingComValueAfterLabel_(lines, /Check-?out|Trả phòng/i);
  var stay = extractBookingComValueAfterLabel_(lines, /Length of stay|Thời gian lưu trú/i);
  var totalPrice = extractBookingComMoneyNearLabel_(lines, /Total price|Tổng giá/i);
  var commission = extractBookingComMoneyNearLabel_(lines, /Commission|Hoa hồng/i);
  var commissionable = extractBookingComMoneyNearLabel_(lines, /Commissionable amount|Khoản có tính hoa hồng/i);

  md.push('# Booking.com PDF Normalized Markdown');
  md.push('- Source file: ' + (fileName || 'Drive PDF'));
  md.push('- Booking number: ' + bookingId);
  md.push('- Guest name: ' + guest);
  md.push('- Total guests: ' + totalGuests);
  md.push('- Total units/rooms: ' + rooms);
  md.push('- Check-in: ' + checkIn);
  md.push('- Check-out: ' + checkOut);
  md.push('- Length of stay: ' + stay);
  md.push('');
  md.push('## Financial Summary');
  md.push('- Total price: ' + totalPrice);
  md.push('- Commission: ' + commission);
  md.push('- Commissionable amount: ' + commissionable);
  md.push('');
  md.push('## Room And Daily Rate Lines');

  var currentRoomNo = 0;
  for (var i = 0; i < lines.length; i++) {
    var line = lines[i];
    if (/room|apartment|suite|villa|studio|bungalow/i.test(line) && /\b\d+G\s*\d+M\d+\b/i.test(line)) {
      currentRoomNo++;
      md.push('');
      md.push('### Room ' + currentRoomNo);
      md.push('- Room type: ' + line);
      if (lines[i + 1] && /meal|breakfast|ăn sáng|bữa sáng|bao gồm bữa ăn|bao gồm bữa sáng/i.test(lines[i + 1])) {
        md.push('- Meal: ' + lines[i + 1]);
      }
      continue;
    }

    if (/^(\d{1,2})\s+([A-Za-z]{3,9})\s+(\d{4})\b/i.test(line) && /VND\s*[\d.,]+/i.test(line)) {
      md.push('- Daily rate: ' + line);
      continue;
    }

    if (/(\d{1,2})\s*-\s*(\d{1,2})\s+([A-Za-z]{3,9})\s+(\d{4})/i.test(line) && /VND\s*[\d.,]+/i.test(line)) {
      md.push('- Range rate: ' + line);
      continue;
    }

    if (/Total unit\/room price|Tổng giá căn\/phòng/i.test(line)) {
      var money = extractBookingComMoneyFromNearbyLines_(lines, i, 3);
      md.push('- Unit total: ' + money);
    }
  }

  md.push('');
  md.push('## Raw Text');
  md.push('```text');
  md.push(text);
  md.push('```');
  return md.join('\n');
}

function extractBookingComValueAfterLabel_(lines, labelRegex) {
  for (var i = 0; i < lines.length; i++) {
    if (labelRegex.test(lines[i])) return lines[i + 1] || '';
    var sameLine = lines[i].match(new RegExp(labelRegex.source + '\\s*:?\\s*(.+)$', 'i'));
    if (sameLine) return sameLine[1];
  }
  return '';
}

function extractBookingComMoneyNearLabel_(lines, labelRegex) {
  for (var i = 0; i < lines.length; i++) {
    if (labelRegex.test(lines[i])) return extractBookingComMoneyFromNearbyLines_(lines, i, 3);
  }
  return '';
}

function extractBookingComMoneyFromNearbyLines_(lines, startIndex, lookAhead) {
  for (var j = startIndex; j <= Math.min(lines.length - 1, startIndex + lookAhead); j++) {
    var m = (lines[j] || '').match(/VND\s*[\d.,]+/i);
    if (m) return m[0];
  }
  return '';
}

function extractBookingComUnitRates(cleanText, finalData) {
  var text = cleanText || "";
  var checkInBase = parseDateToSheetFormat(finalData.check_in);
  var year = inferBookingYear_(checkInBase, finalData.check_in);
  var lines = text.split(/\r?\n/).map(function(line) { return (line || '').trim(); }).filter(function(line) { return line; });

  // Xây dựng danh sách room blocks
  // Mỗi block bắt đầu khi gặp header phòng (Room/Apartment/Suite... + mã phòng)
  var blocks = [];
  var currentBlock = null;

  for (var i = 0; i < lines.length; i++) {
    var line = lines[i];

    // Phát hiện header phòng mới → lưu block cũ, bắt đầu block mới
    if (/room|apartment|suite|villa|studio|bungalow/i.test(line) && /\b\d+G\s*\d+M\d+\b/i.test(line)) {
      if (currentBlock) blocks.push(currentBlock);
      var blockMeal = (lines[i + 1] && /meal|breakfast|ăn sáng|bữa sáng|bao gồm/i.test(lines[i + 1])) ? lines[i + 1] : "";
      currentBlock = {
        room_type: line,
        meal: blockMeal,
        dailyPrices: [],
        firstCheckIn: null,
        lastCheckOut: null
      };
      continue;
    }

    if (!currentBlock) continue;

    // Giá từng ngày: "15 May 2026 ... 1 x VND 400.950"
    var singleDateMatch = line.match(/(\d{1,2})\s+([A-Za-z]{3,9})\s+(\d{4})\b/i);
    var priceMatch = line.match(/(?:\d+\s*x\s*)?VND\s*([\d.,]+)/i);

    if (singleDateMatch && priceMatch) {
      var monthNum = monthNameToNumber_(singleDateMatch[2]);
      var day = parseInt(singleDateMatch[1], 10);
      var dateYear = parseInt(singleDateMatch[3], 10) || year;
      if (monthNum) {
        var stayDate = new Date(dateYear, monthNum - 1, day);
        var nextDate = new Date(stayDate.getTime());
        nextDate.setDate(nextDate.getDate() + 1);
        var gross = parseFloat(cleanMoneyString(priceMatch[1])) || 0;

        if (!currentBlock.firstCheckIn || stayDate < currentBlock.firstCheckIn) {
          currentBlock.firstCheckIn = stayDate;
        }
        if (!currentBlock.lastCheckOut || nextDate > currentBlock.lastCheckOut) {
          currentBlock.lastCheckOut = nextDate;
        }
        currentBlock.dailyPrices.push(gross);
      }
      continue;
    }

    // Khoảng ngày: "28 - 29 Mar 2026 ... 1 x VND 684.000"
    var rangeMatch = line.match(/(\d{1,2})\s*-\s*(\d{1,2})\s+([A-Za-z]{3,9})\s+(\d{4})/i);
    if (rangeMatch && priceMatch) {
      var rMonthNum = monthNameToNumber_(rangeMatch[3]);
      var startDay = parseInt(rangeMatch[1], 10);
      var endDay = parseInt(rangeMatch[2], 10);
      var rYear = parseInt(rangeMatch[4], 10) || year;
      if (rMonthNum) {
        var rangeStart = new Date(rYear, rMonthNum - 1, startDay);
        var rangeEnd = new Date(rYear, rMonthNum - 1, endDay);
        var rangeGross = parseFloat(cleanMoneyString(priceMatch[1])) || 0;

        if (!currentBlock.firstCheckIn || rangeStart < currentBlock.firstCheckIn) {
          currentBlock.firstCheckIn = rangeStart;
        }
        if (!currentBlock.lastCheckOut || rangeEnd > currentBlock.lastCheckOut) {
          currentBlock.lastCheckOut = rangeEnd;
        }
        currentBlock.dailyPrices.push(rangeGross);
      }
      continue;
    }
  }

  // Đẩy block cuối cùng
  if (currentBlock) blocks.push(currentBlock);

  if (blocks.length === 0) return [];

  // Chuyển từng block thành 1 dòng kết quả
  var totalPrice = parseFloat(cleanMoneyString(finalData.total_price)) || 0;
  var totalCommission = parseFloat(cleanMoneyString(finalData.commission)) || 0;
  var totalNet = parseFloat(cleanMoneyString(finalData.net_rate)) || 0;

  var rates = [];
  for (var b = 0; b < blocks.length; b++) {
    var block = blocks[b];
    if (block.dailyPrices.length === 0) continue;

    // Cộng tổng giá các ngày trong block này
    var blockGross = 0;
    for (var p = 0; p < block.dailyPrices.length; p++) {
      blockGross += block.dailyPrices[p];
    }

    // Tính hoa hồng và thực nhận theo tỷ lệ
    var blockCommission = totalPrice > 0 ? Math.round(blockGross * totalCommission / totalPrice) : 0;
    var blockNet = totalPrice > 0 ? Math.round(blockGross * totalNet / totalPrice) : blockGross;
    if (!blockNet) blockNet = blockGross;

    var blockMealText = block.meal || '';
    var breakfastValue = /no\s*meal|không|không bao gồm/i.test(blockMealText) ? "Không" : (blockMealText || finalData.breakfast || "Không");

    rates.push({
      check_in: block.firstCheckIn ? formatDateToSheetStr(block.firstCheckIn) : finalData.check_in,
      check_out: block.lastCheckOut ? formatDateToSheetStr(block.lastCheckOut) : finalData.check_out,
      room_type: block.room_type,
      rooms: 1,
      gross: blockGross.toString(),
      commission: blockCommission.toString(),
      net_rate: blockNet.toString(),
      surcharge: "0",
      other_programs: "0",
      breakfast: breakfastValue
    });
  }

  return rates;
}

function buildBookingComFallbackRoomNightRates_(finalData, finalRoomType) {
  var checkInDate = dateFromAnySheetValue_(finalData.check_in);
  var checkOutDate = dateFromAnySheetValue_(finalData.check_out);
  if (!checkInDate || !checkOutDate) return [];

  var roomCount = parseInt(finalData.rooms, 10) || 1;
  var nightCount = Math.max(1, Math.round((checkOutDate.getTime() - checkInDate.getTime()) / (24 * 60 * 60 * 1000)));

  // Nếu chỉ 1 phòng 1 đêm thì không cần bung fallback.
  if (roomCount <= 1 && nightCount <= 1) return [];

  var totalRows = roomCount * nightCount;
  var grossTotal = parseFloat(cleanMoneyString(finalData.total_price)) || 0;
  var commissionTotal = parseFloat(cleanMoneyString(finalData.commission)) || 0;
  var surchargeTotal = parseFloat(cleanMoneyString(finalData.surcharge)) || 0;
  var otherProgramsTotal = parseFloat(cleanMoneyString(finalData.other_programs)) || 0;
  var netTotal = parseFloat(cleanMoneyString(finalData.net_rate)) || grossTotal;

  var grossPerRow = Math.round(grossTotal / totalRows);
  var commissionPerRow = Math.round(commissionTotal / totalRows);
  var surchargePerRow = Math.round(surchargeTotal / totalRows);
  var otherProgramsPerRow = Math.round(otherProgramsTotal / totalRows);
  var netPerRow = Math.round(netTotal / totalRows);

  var rows = [];
  for (var r = 0; r < roomCount; r++) {
    for (var n = 0; n < nightCount; n++) {
      var stayDate = new Date(checkInDate.getTime());
      stayDate.setDate(stayDate.getDate() + n);
      var nextDate = new Date(stayDate.getTime());
      nextDate.setDate(nextDate.getDate() + 1);

      rows.push({
        check_in: formatDateToSheetStr(stayDate),
        check_out: formatDateToSheetStr(nextDate),
        room_type: finalRoomType || finalData.room_type || 'Booking.com Room',
        rooms: 1,
        gross: grossPerRow.toString(),
        commission: commissionPerRow.toString(),
        net_rate: netPerRow.toString(),
        surcharge: surchargePerRow.toString(),
        other_programs: otherProgramsPerRow.toString(),
        breakfast: finalData.breakfast || 'Không'
      });
    }
  }

  return rows;
}

function formatBookingComRoomType_(roomText, roomQty) {
  var text = (roomText || '').toString().trim();
  var qty = roomQty || 1;

  // Ưu tiên mã phòng nội bộ dạng 2G1M6, 1G1M8...
  var codeMatch = text.match(/\b(\d+G\s*\d+M\d+)\b/i);
  if (codeMatch) {
    return codeMatch[1].replace(/\s+/g, '').toUpperCase() + ' (x' + qty + ')';
  }

  // Fallback nếu mã nằm trong ngoặc hoặc dạng code chữ/số
  codeMatch = text.match(/\(([A-Z0-9]{3,})\)/i);
  if (codeMatch) {
    return codeMatch[1].toUpperCase() + ' (x' + qty + ')';
  }

  return text ? (text + ' (x' + qty + ')') : ('Booking.com Room (x' + qty + ')');
}

function monthNameToNumber_(monthName) {
  var key = (monthName || '').toString().toLowerCase().substring(0, 3);
  var map = {jan:1,feb:2,mar:3,apr:4,may:5,jun:6,jul:7,aug:8,sep:9,oct:10,nov:11,dec:12};
  return map[key] || null;
}

function calculateProportionalAmount_(partAmount, totalAmount, targetAmount) {
  var part = parseFloat(cleanMoneyString(partAmount)) || 0;
  var total = parseFloat(cleanMoneyString(totalAmount)) || 0;
  var target = parseFloat(cleanMoneyString(targetAmount)) || 0;
  if (!part || !total || !target) return "0";
  return Math.round(part * target / total).toString();
}

function extractTripComDailyRates(cleanText, finalData) {
  var text = cleanText || "";
  var checkInBase = parseDateToSheetFormat(finalData.check_in);
  var year = inferBookingYear_(checkInBase, finalData.check_in);

  // Pattern 1: Tiếng Anh - "Jun 14 (1 room(s))"
  var MONTH_MAP = {Jan:1,Feb:2,Mar:3,Apr:4,May:5,Jun:6,Jul:7,Aug:8,Sep:9,Oct:10,Nov:11,Dec:12};
  var enRegex = /(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\s+(\d{1,2})\s*\(\d+\s*room\(s\)\)/gi;
  var matches = [];
  var match;
  while ((match = enRegex.exec(text)) !== null) {
    var monthNum = MONTH_MAP[match[1].charAt(0).toUpperCase() + match[1].substring(1).toLowerCase()];
    if (monthNum) {
      matches.push({ index: match.index, day: parseInt(match[2], 10), month: monthNum });
    }
  }

  // Pattern 2: Tiếng Việt fallback - "Ngày 14 tháng 6 (1 phòng)"
  if (matches.length === 0) {
    var viRegex = /Ngày\s+(\d{1,2})\s+tháng\s+(\d{1,2})\s*\([^)]*phòng[^)]*\)/gi;
    while ((match = viRegex.exec(text)) !== null) {
      matches.push({ index: match.index, day: parseInt(match[1], 10), month: parseInt(match[2], 10) });
    }
  }

  if (matches.length === 0) return [];

  var rates = [];
  for (var i = 0; i < matches.length; i++) {
    var start = matches[i].index;
    var end = (i + 1 < matches.length) ? matches[i + 1].index : Math.min(text.length, start + 2000);
    var block = text.substring(start, end);

    var stayDate = new Date(year, matches[i].month - 1, matches[i].day);
    var nextDate = new Date(stayDate.getTime());
    nextDate.setDate(nextDate.getDate() + 1);

    // Lấy giá từ block - ưu tiên Your payout làm Net
    var gross = extractTripComMoneyAfterKey_(block, /Original room rate/i)
             || extractTripComMoneyAfterKey_(block, /Giá phòng ban đầu/i);
    var discount = extractTripComDiscount_(block);
    var net = extractTripComMoneyAfterKey_(block, /Your payout/i)
           || extractTripComMoneyAfterKey_(block, /Khoản thanh toán của bạn/i);

    // Fallback: Final room rate
    if (!net || net === "0") {
      net = extractTripComMoneyAfterKey_(block, /Final room rate/i)
         || extractTripComMoneyAfterKey_(block, /Giá phòng cuối cùng/i);
    }

    if (net && net !== "0" && net !== 0) {
      rates.push({
        check_in: formatDateToSheetStr(stayDate),
        check_out: formatDateToSheetStr(nextDate),
        gross: gross || "0",
        commission: discount || "0",
        net_rate: net,
        surcharge: "0",
        other_programs: "0"
      });
    }
  }

  return rates;
}

function formatDateToSheetStr(dateObj) {
  var d = dateObj.getDate();
  var m = dateObj.getMonth() + 1;
  var y = dateObj.getFullYear();
  return (d < 10 ? '0'+d : d) + '/' + (m < 10 ? '0'+m : m) + '/' + y;
}

function dateFromAnySheetValue_(value) {
  if (!value) return null;

  if (Object.prototype.toString.call(value) === '[object Date]' && !isNaN(value.getTime())) {
    return new Date(value.getFullYear(), value.getMonth(), value.getDate());
  }

  var parsed = parseDateToSheetFormat(value);
  if (Object.prototype.toString.call(parsed) === '[object Date]' && !isNaN(parsed.getTime())) {
    return new Date(parsed.getFullYear(), parsed.getMonth(), parsed.getDate());
  }

  var s = (parsed || value || "").toString().trim();
  var m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (m) return new Date(parseInt(m[3], 10), parseInt(m[2], 10) - 1, parseInt(m[1], 10));

  m = s.match(/^(\d{1,2})-(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*-(\d{4})/i);
  if (m) {
    var monthMap = {jan:0,feb:1,mar:2,apr:3,may:4,jun:5,jul:6,aug:7,sep:8,oct:9,nov:10,dec:11};
    var mon = s.match(/-(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*-/i)[1].toLowerCase().substring(0,3);
    return new Date(parseInt(m[2], 10), monthMap[mon], parseInt(m[1], 10));
  }

  var auto = new Date(s);
  if (!isNaN(auto.getTime())) return new Date(auto.getFullYear(), auto.getMonth(), auto.getDate());
  return null;
}

function dateFromTravelokaDate_(dateText) {
  if (!dateText) return null;
  var monthMap = {jan:0,feb:1,mar:2,apr:3,may:4,jun:5,jul:6,aug:7,sep:8,oct:9,nov:10,dec:11};
  var m = dateText.toString().trim().match(/^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\s+(\d{1,2}),\s*(\d{4})$/i);
  if (!m) return dateFromAnySheetValue_(dateText);
  return new Date(parseInt(m[3], 10), monthMap[m[1].toLowerCase().substring(0, 3)], parseInt(m[2], 10));
}

function extractTravelokaDailyRates(cleanText, finalData) {
  var text = cleanText || "";
  var dateIn = dateFromAnySheetValue_(finalData.check_in);
  var dateOut = dateFromAnySheetValue_(finalData.check_out);
  if (!dateIn || !dateOut) return [];

  var nights = Math.round((dateOut - dateIn) / (1000 * 60 * 60 * 24));
  if (nights <= 1) return [];

  var totalNet = cleanMoneyString(finalData.net_rate);
  var totalGross = cleanMoneyString(finalData.total_price);
  var totalSurcharge = cleanMoneyString(finalData.surcharge);
  var totalOther = cleanMoneyString(finalData.other_programs);

  var rows = [];

  // ═══════════════════════════════════════════════════════════════════
  // BLOCK-BASED PARSER: Tìm ngày trước, rồi quét VND values trong block.
  // Xử lý được: dấu "|", "x 2 phòng", "VND trước số" và "số trước VND".
  // ═══════════════════════════════════════════════════════════════════
  var normalized = text.replace(/\|/g, ' ').replace(/\s+/g, ' ');

  // Tìm tất cả date markers (English + Vietnamese)
  var datePattern = /(?:((?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\s+\d{1,2},\s*20\d{2})|Ng[àa]y\s+(\d{1,2})\s+th[áa]ng\s+(\d{1,2})\s+n[aă]m\s+(20\d{2}))/gi;
  var dateMatches = [];
  var match;
  while ((match = datePattern.exec(normalized)) !== null) {
    var stayDate;
    if (match[1]) {
      stayDate = dateFromTravelokaDate_(match[1]);
    } else {
      stayDate = new Date(parseInt(match[4], 10), parseInt(match[3], 10) - 1, parseInt(match[2], 10));
    }
    if (stayDate) {
      dateMatches.push({ index: match.index, endIndex: match.index + match[0].length, date: stayDate });
    }
  }

  if (dateMatches.length === 0) return [];

  // Quét VND values trong từng block (từ date đến date tiếp theo)
  for (var i = 0; i < dateMatches.length; i++) {
    var start = dateMatches[i].endIndex;
    var end = (i + 1 < dateMatches.length) ? dateMatches[i + 1].index : Math.min(normalized.length, start + 500);
    var block = normalized.substring(start, end);

    // Tìm tất cả số tiền VND trong block
    // Hỗ trợ: "VND 450000", "450.000 VND", "VND 0", "0 VND"
    // Bỏ qua: "x 2", "x 2 phòng", "x2" (multiplier, không phải tiền)
    var amounts = [];
    var vndScan = /(?:VND\s*([\d,.]+)|([\d,.]+)\s*VND)/gi;
    var vm;
    while ((vm = vndScan.exec(block)) !== null) {
      var raw = vm[1] || vm[2];
      // Bỏ qua nếu số đứng sau "x" (multiplier)
      var before = block.substring(Math.max(0, vm.index - 3), vm.index);
      if (/x\s*$/i.test(before)) continue;
      amounts.push(cleanMoneyString(raw));
    }

    if (amounts.length < 2) continue;

    // Traveloka bảng giá có 4 cột: Room Rate, Extra Bed, Surcharge, Subtotal
    // Chỉ lấy tối đa 4 giá trị VND đầu tiên, tránh bắt nhầm dòng tổng (Subtotal Rates)
    if (amounts.length > 4) amounts = amounts.slice(0, 4);

    var sd = dateMatches[i].date;
    var nd = new Date(sd);
    nd.setDate(nd.getDate() + 1);

    // Map: amounts = [roomRate, extraBed, surcharge, subtotal] hoặc ít hơn
    var subtotal = amounts[amounts.length - 1];
    var surcharge = amounts.length >= 4 ? amounts[amounts.length - 2] : 0;

    rows.push({
      check_in: formatDateToSheetStr(sd),
      check_out: formatDateToSheetStr(nd),
      gross: subtotal,
      commission: 0,
      net_rate: subtotal,
      surcharge: surcharge,
      other_programs: 0
    });
  }

  // Nếu tìm được >= 2 dòng giá ngày thì dùng, không bắt buộc khớp chính xác nights từ AI
  // (vì AI có thể trả sai ngày check-in/check-out)
  if (rows.length < 2) return [];

  // Nếu tổng có adjustment/coupon, phân bổ vào net/other theo tỷ lệ và dòng cuối hấp thụ sai số.
  var sumGross = 0;
  for (var i = 0; i < rows.length; i++) sumGross += cleanMoneyString(rows[i].gross);
  if (!totalGross) totalGross = sumGross;
  if (!totalNet) totalNet = totalGross;

  var sumNet = 0, sumOther = 0, sumSurcharge = 0;
  for (var j = 0; j < rows.length; j++) {
    var gross = cleanMoneyString(rows[j].gross);
    var ratio = totalGross > 0 ? (gross / totalGross) : (1 / rows.length);
    if (j < rows.length - 1) {
      rows[j].net_rate = Math.round(totalNet * ratio);
      rows[j].other_programs = Math.round(totalOther * ratio);
      rows[j].surcharge = Math.round(totalSurcharge * ratio);
      sumNet += rows[j].net_rate;
      sumOther += rows[j].other_programs;
      sumSurcharge += rows[j].surcharge;
    } else {
      rows[j].net_rate = totalNet - sumNet;
      rows[j].other_programs = totalOther - sumOther;
      rows[j].surcharge = totalSurcharge - sumSurcharge;
    }
  }

  return rows;
}

function extractAirbnbDailyRates(cleanText, finalData) {
  var dateIn = dateFromAnySheetValue_(finalData.check_in);
  var dateOut = dateFromAnySheetValue_(finalData.check_out);
  if (!dateIn || !dateOut) return [];

  var nights = Math.round((dateOut - dateIn) / (1000 * 60 * 60 * 24));
  if (nights <= 1) return [];

  // Airbnb thường email summary không luôn có bảng giá từng ngày.
  // Khi chưa bắt được bảng giá ngày rõ ràng, chia đều tổng tiền để đảm bảo đủ dòng vận hành.
  var totalNet = cleanMoneyString(finalData.net_rate);
  var totalGross = cleanMoneyString(finalData.total_price);
  var totalComm = cleanMoneyString(finalData.commission);
  var totalSurcharge = cleanMoneyString(finalData.surcharge);
  var totalOther = cleanMoneyString(finalData.other_programs);

  if (!totalNet && !totalGross) return [];
  if (!totalGross) totalGross = totalNet;
  if (!totalNet) totalNet = totalGross;

  var rows = [];
  var current = new Date(dateIn);
  var sumGross = 0, sumNet = 0, sumComm = 0, sumSurcharge = 0, sumOther = 0;

  for (var i = 0; i < nights; i++) {
    var nextDay = new Date(current);
    nextDay.setDate(nextDay.getDate() + 1);

    var gross = (i < nights - 1) ? Math.round(totalGross / nights) : (totalGross - sumGross);
    var net = (i < nights - 1) ? Math.round(totalNet / nights) : (totalNet - sumNet);
    var comm = (i < nights - 1) ? Math.round(totalComm / nights) : (totalComm - sumComm);
    var surcharge = (i < nights - 1) ? Math.round(totalSurcharge / nights) : (totalSurcharge - sumSurcharge);
    var other = (i < nights - 1) ? Math.round(totalOther / nights) : (totalOther - sumOther);

    rows.push({
      check_in: formatDateToSheetStr(current),
      check_out: formatDateToSheetStr(nextDay),
      gross: gross,
      commission: comm,
      net_rate: net,
      surcharge: surcharge,
      other_programs: other
    });

    sumGross += gross;
    sumNet += net;
    sumComm += comm;
    sumSurcharge += surcharge;
    sumOther += other;
    current.setDate(current.getDate() + 1);
  }

  return rows;
}

function extractAgodaDailyRates(cleanText, finalData) {
  var text = cleanText || "";
  var dateIn = dateFromAnySheetValue_(finalData.check_in);
  var dateOut = dateFromAnySheetValue_(finalData.check_out);

  if (!dateIn || !dateOut) return [];

  var nights = Math.round((dateOut - dateIn) / (1000 * 60 * 60 * 24));
  if (nights <= 1) return []; // Fallback to 1 row if 1 night or less
  
  var current = new Date(dateIn);
  var dailyNets = [];
  var sumExtractedNet = 0;
  var monthNamesEn = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  
  for (var i = 0; i < nights; i++) {
    var d = current.getDate();
    var m = current.getMonth() + 1;
    var y = current.getFullYear();
    
    var monEn = monthNamesEn[m - 1];
    var dStr = "(?:0?" + d + ")";
    var mStr = "(?:" + monEn + "|Tháng\\s*0?" + m + ")";
    var yStr = y.toString();
    
    // Pattern: "May 21, 2026" or "21 May 2026" or "Tháng 5 21, 2026" or "21 Tháng 5 2026"
    var datePattern = new RegExp("(?:" + mStr + "\\s+" + dStr + "\\s*,?\\s*" + yStr + "|" + dStr + "\\s+" + mStr + "\\s*,?\\s*" + yStr + ")", "i");
    
    var match = text.match(datePattern);
    if (match) {
       var snippet = text.substring(match.index, Math.min(text.length, match.index + 150));
       var currencyMatch = snippet.match(/(?:VND|USD|EUR|THB|AUD|SGD|GBP|JPY|KRW|MYR|PHP|IDR)\s*[|:]?\s*([\d,]+(?:\.\d+)?)/i);
       var net = 0;
       
       if (currencyMatch) {
         net = cleanMoneyString(currencyMatch[1]);
       } else {
         var nums = snippet.substring(match[0].length).match(/[\d,]+(?:\.\d+)?/g);
         if (nums) {
           for (var k = 0; k < nums.length; k++) {
             var val = cleanMoneyString(nums[k]);
             if (val > 10) {
               net = val;
               break;
             }
           }
         }
       }
       
       if (net > 0) {
         var nextDay = new Date(current);
         nextDay.setDate(nextDay.getDate() + 1);
         dailyNets.push({
           check_in: formatDateToSheetStr(current),
           check_out: formatDateToSheetStr(nextDay),
           net_rate: net,
           gross: 0,
           commission: 0,
           surcharge: 0,
           other_programs: 0
         });
         sumExtractedNet += net;
       }
    }
    current.setDate(current.getDate() + 1);
  }
  
  if (dailyNets.length !== nights) return [];
  
  var totalGross = cleanMoneyString(finalData.total_price);
  var totalComm = cleanMoneyString(finalData.commission);
  var commSign = (finalData.commission && finalData.commission.toString().indexOf("-") > -1) ? -1 : 1;
  if (totalComm > 0 && commSign === -1) totalComm = -totalComm; 
  
  var totalSurcharge = cleanMoneyString(finalData.surcharge);
  var totalOther = cleanMoneyString(finalData.other_programs);
  
  var sumGross = 0, sumComm = 0, sumSurcharge = 0, sumOther = 0;
  
  for (var i = 0; i < dailyNets.length; i++) {
    var ratio = sumExtractedNet > 0 ? (dailyNets[i].net_rate / sumExtractedNet) : (1 / nights);
    
    if (i < dailyNets.length - 1) {
      dailyNets[i].gross = Math.round(totalGross * ratio);
      dailyNets[i].commission = Math.round(totalComm * ratio);
      dailyNets[i].surcharge = Math.round(totalSurcharge * ratio);
      dailyNets[i].other_programs = Math.round(totalOther * ratio);
      
      sumGross += dailyNets[i].gross;
      sumComm += dailyNets[i].commission;
      sumSurcharge += dailyNets[i].surcharge;
      sumOther += dailyNets[i].other_programs;
    } else {
      dailyNets[i].gross = totalGross - sumGross;
      dailyNets[i].commission = totalComm - sumComm;
      dailyNets[i].surcharge = totalSurcharge - sumSurcharge;
      dailyNets[i].other_programs = totalOther - sumOther;
    }
  }
  
  return dailyNets;
}

function extractExpediaDailyRates(cleanText, finalData) {
  var text = cleanText || "";
  var dateIn = dateFromAnySheetValue_(finalData.check_in);
  var dateOut = dateFromAnySheetValue_(finalData.check_out);
  if (!dateIn || !dateOut) return [];

  var nights = Math.round((dateOut - dateIn) / (1000 * 60 * 60 * 24));
  if (nights <= 1) return [];

  var totalGross = cleanMoneyString(finalData.total_price);
  var totalNet = cleanMoneyString(finalData.net_rate);
  // Expedia: không tự suy luận hoa hồng từ chênh lệch Gross/Net.
  // Chỉ dùng commission nếu email/AI quét được trường commission rõ ràng.
  var totalComm = cleanMoneyString(finalData.commission);

  // Mẫu Expedia: "Giá cơ sở mỗi ngày - Trọn gói - 1,379,507 VND"
  var baseRate = findExpediaBaseDailyRate_(text);

  var rates = [];
  var current = new Date(dateIn);
  var sumNet = 0;
  var sumComm = 0;

  for (var i = 0; i < nights; i++) {
    var nextDay = new Date(current);
    nextDay.setDate(nextDay.getDate() + 1);

    // Expedia: "Giá cơ sở mỗi ngày" = đơn giá CHƯA thuế → dùng cho TẤT CẢ đêm
    var gross;
    if (baseRate > 0) {
      gross = baseRate;
    } else {
      gross = (i < nights - 1) ? Math.round(totalGross / nights) : (totalGross - rates.reduce(function(s,r){return s+r.gross;},0));
    }

    var ratio = (1 / nights);
    var net = (i < nights - 1) ? Math.round(totalNet / nights) : (totalNet - sumNet);
    var comm = (i < nights - 1) ? Math.round(totalComm / nights) : (totalComm - sumComm);

    rates.push({
      check_in: formatDateToSheetStr(current),
      check_out: formatDateToSheetStr(nextDay),
      gross: gross,
      commission: comm,
      net_rate: net,
      surcharge: 0,
      other_programs: 0
    });

    sumNet += net;
    sumComm += comm;
    current.setDate(current.getDate() + 1);
  }

  return rates;
}

function findExpediaBaseDailyRate_(text) {
  var m = text.match(/(?:Giá cơ sở mỗi ngày|Base rate per day|Daily base rate)[^\d-]*((?:-|−)?[\d,.]+)\s*VND/i);
  if (m) return cleanMoneyString(m[1]);

  // Fallback: lấy số tiền đứng ngay trước VND trong block giá cơ sở.
  var idx = text.search(/Giá cơ sở mỗi ngày|Base rate per day|Daily base rate/i);
  if (idx === -1) return 0;
  var snippet = text.substring(idx, Math.min(text.length, idx + 250));
  var nums = snippet.match(/((?:-|−)?[\d,.]+)\s*VND/gi);
  if (!nums || nums.length === 0) return 0;
  return cleanMoneyString(nums[0]);
}

function extractTripComMoneyAfterKey_(block, keyRegex) {
  var m = block.match(keyRegex);
  if (!m) return "0";
  // Lấy phần text từ key đến hết dòng hoặc 300 ký tự
  var snippet = block.substring(m.index, Math.min(block.length, m.index + 300));
  // Tìm số tiền gần nhất sau key (có thể có *1 cuối)
  var nums = snippet.match(/[\d,]+(?:\.\d+)?(?:\*\d+)?/g);
  if (!nums) return "0";

  for (var i = 0; i < nums.length; i++) {
    var cleaned = normalizeTripComMoney_(nums[i]);
    if (cleaned !== "0" && cleaned !== 0 && parseInt(cleaned.toString().replace(/-/g, ""), 10) > 100) return cleaned;
  }
  return "0";
}

function extractTripComDiscount_(block) {
  // Tìm Discounts hoặc Giảm giá
  var m = block.match(/Discounts|Giảm giá/i);
  if (!m) return "0";
  var snippet = block.substring(m.index, Math.min(block.length, m.index + 300));
  // Tìm số âm đầu tiên
  var nums = snippet.match(/(?:-|−)\d[\d,.]*(?:\.\d+)?(?:\*\d+)?/g);
  if (!nums || nums.length === 0) return "0";
  return normalizeTripComMoney_(nums[0]);
}

function normalizeTripComMoney_(value) {
  if (!value) return "0";
  var s = value.toString().replace(/−/g, "-").replace(/\*\d+/g, "").replace(/\+/g, "").trim();
  // Trip.com: 964706.00 -> 964706 (bỏ .00 phần thập phân)
  if (/^-?\d+\.\d{2}$/.test(s)) s = s.replace(/\.\d{2}$/, "");
  // Bỏ dấu phẩy phân cách hàng nghìn
  s = s.replace(/,/g, "");
  return cleanMoneyString(s);
}

function inferBookingYear_(parsedCheckInDate, rawCheckIn) {
  if (parsedCheckInDate && Object.prototype.toString.call(parsedCheckInDate) === '[object Date]' && !isNaN(parsedCheckInDate.getTime())) {
    return parsedCheckInDate.getFullYear();
  }
  var raw = rawCheckIn ? rawCheckIn.toString() : "";
  var y = raw.match(/20\d{2}/);
  return y ? parseInt(y[0], 10) : new Date().getFullYear();
}

function formatDateKey_(value) {
  if (!value) return "";
  if (Object.prototype.toString.call(value) === '[object Date]' && !isNaN(value.getTime())) {
    return Utilities.formatDate(value, Session.getScriptTimeZone(), "yyyy-MM-dd");
  }
  var parsed = parseDateToSheetFormat(value);
  if (Object.prototype.toString.call(parsed) === '[object Date]' && !isNaN(parsed.getTime())) {
    return Utilities.formatDate(parsed, Session.getScriptTimeZone(), "yyyy-MM-dd");
  }
  return value.toString().trim();
}

function hasBookingDateKey_(sheet, compositeKey) {
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return false;
  var target = compositeKey.toString();
  var data = sheet.getRange(2, 4, lastRow - 1, 4).getValues(); // D:G = Mã BK, Tên khách, Check-in, Check-out
  for (var i = 0; i < data.length; i++) {
    var bookingId = data[i][0] ? data[i][0].toString().trim() : "";
    var checkInKey = formatDateKey_(data[i][2]);
    if ((bookingId + "__" + checkInKey) === target) return true;
  }
  return false;
}

// ============================================================================
// MODULE 4: BỘ QUÉT DỮ LIỆU CỨNG (V25 - THÊM TRAVELOKA + EXPEDIA PAYMENT)
// ============================================================================


function detectPlatform(text, subject) {
  if (subject.indexOf("Expedia") > -1 || text.indexOf("Khoản tiền thu từ Expedia") > -1) return "Expedia";
  if (text.indexOf("Trip.com") > -1 || text.indexOf("auto_reservation@trip.com") > -1) return "Trip.com";
  if (text.indexOf("Airbnb") > -1 || text.indexOf("HMCS") > -1) return "Airbnb";
  if (text.indexOf("Traveloka") > -1 || text.indexOf("hotel@traveloka.com") > -1) return "Traveloka"; // ✅ V25
  return "Agoda"; 
}



function scanDataByPlatform(text, platform) {
  var data = {
    net_rate: "0", total_price: "0", commission: "0", 
    surcharge: "0", other_programs: "0", has_breakfast: "Không"
  };


  if (platform === "Expedia") {
    data.net_rate = findValueNearKey(text, /Khoản tiền thu từ Expedia Group/i);
    data.total_price = findValueNearKey(text, /Tổng khoản tiền đặt phòng/i);

    // ═══════════════════════════════════════════════════════════════════
    // ✅ V25: Quét Payment Status bằng regex (từ email mẫu thực tế)
    // ═══════════════════════════════════════════════════════════════════
    if (/THANH TOÁN TRƯỚC|Expedia thu khoản thanh toán từ khách/i.test(text)) {
      data.payment_status = "Prepaid";
    } else if (/Khách sạn thu tiền thanh toán|Khách sạn thu khoản thanh toán từ khách/i.test(text)) {
      data.payment_status = "Postpaid";
    }

    // Expedia: không tự tính hoa hồng = Net - Gross.
    // Nếu email không có dòng Commission rõ ràng thì giữ Hoa Hồng = 0.
    data.commission = findValueNearKey(text, /(?:Commission|Hoa hồng|Tiền hoa hồng)/i);

  } else if (platform === "Trip.com") {
    // ✅ FIX V26: Sửa lại cách lấy dữ liệu Trip.com theo feedback
    // Tổng Tiền (Gross) = Giá phòng ban đầu
    // Thực nhận = Khoản thanh toán của bạn
    // Hoa hồng = Giảm giá
    data.net_rate = findValueNearKey(text, /(?:Khoản thanh toán của bạn|Your payout|Settlement Price|Net Price)/i);
    data.total_price = findValueNearKey(text, /(?:Giá phòng ban đầu|Original room rate|Total Amount)/i);
    
    var discountMatch = text.match(/(?:Giảm giá|Discount)[^0-9-]*((?:-|−)?[\d,.]+)/i);
    if (discountMatch) {
      data.commission = discountMatch[1];
    } else {
      data.commission = findValueNearKey(text, /(?:Giảm giá|Discount)/i);
    }


  } else if (platform === "Airbnb") {
    var airbnbDates = extractAirbnbStayDates_(text);
    if (airbnbDates) {
      data.check_in = airbnbDates.check_in;
      data.check_out = airbnbDates.check_out;
    }

    data.net_rate = findValueNearKey(text, /(?:Bạn kiếm được|Bạn sẽ nhận được|Host payout|Payout|Total payout|Your payout)/i);
    data.total_price = findValueNearKey(text, /(?:Tổng \(VND\)|Guest paid|Guest total|Total paid by guest|Total price|Subtotal)/i);
    data.commission = findValueNearKey(text, /(?:Phí dịch vụ|Service fee|Host service fee)/i);
    data.surcharge = findValueNearKey(text, /(?:Phí dọn dẹp|Cleaning fee|Điều chỉnh|Adjustment)/i);
    data.payment_status = "Prepaid";


  // ═══════════════════════════════════════════════════════════════════
  // ✅ V25: TRAVELOKA - Quét dữ liệu giá tiền (CẬP NHẬT TỪ MẪU THỰC TẾ)
  // Từ khóa: "Tổng phụ Tỷ lệ", "Tổng số tiền bạn sẽ nhận được", "Giá phòng"
  // ═══════════════════════════════════════════════════════════════════
  } else if (platform === "Traveloka") {

    // --- Thực nhận (Net) - ƯU TIÊN tìm trước ---
    data.net_rate = findValueNearKey(text, /(?:Tổng số tiền bạn sẽ nhận được|Tổng số tiền bạn sẽ nhận|bạn sẽ nhận được|Total you will receive)/i);
    if (data.net_rate === "0") {
      data.net_rate = findValueNearKey(text, /(?:Hotel Receives|Thanh toán cho khách sạn|Net Amount|Amount to Hotel)/i);
    }

    // --- Tổng cộng (Gross) ---
    data.total_price = findValueNearKey(text, /(?:Tổng phụ Tỷ lệ|Tổng phụ|Subtotal Rates)/i);
    if (data.total_price === "0") {
      data.total_price = findValueNearKey(text, /(?:Total Price|Tổng giá|Total Amount|Tổng cộng)/i);
    }
    if (data.total_price === "0") {
      data.total_price = findValueNearKey(text, /(?:Total Price|Tổng giá|Total Amount|Tổng cộng)/i);
    }
    // Nếu vẫn không tìm được, thử lấy từ "Giá phòng"
    if (data.total_price === "0") {
      data.total_price = findValueNearKey(text, /Giá phòng/i);
    }
    // Nếu tất cả đều 0, dùng net_rate làm total_price
    if (data.total_price === "0" && data.net_rate !== "0") {
      data.total_price = data.net_rate;
    }

    // --- Bù trừ / Điều chỉnh ---
    var discountMatch = text.match(/(?:Điều chỉnh thăng chức và làm tròn|Điều chỉnh)[^0-9-]*((?:-|−)?[\d,.]+)/i);
    if (discountMatch) {
      data.surcharge = discountMatch[1];
    }
    
    // --- Hoa hồng ---
    data.commission = findValueNearKey(text, /(?:Commission|Hoa hồng)/i);

    // --- Ăn sáng (check KHÔNG TRƯỚC, hỗ trợ cả tiếng Anh + Việt) ---
    if (/Breakfast Not Included|Not Included.*Breakfast/i.test(text)) {
      data.has_breakfast = "Không";
    } else if (/không bao gồm/i.test(text) && /(?:sáng|breakfast|bữa ăn)/i.test(text)) {
      data.has_breakfast = "Không";
    } else if (/(Breakfast Included|Kèm bữa sáng|BF Included|Ăn sáng.*bao gồm|bao gồm.*ăn sáng)/i.test(text)) {
      data.has_breakfast = "Có";
    }

    // --- Payment Status ---
    if (/Trả trước|Đã đặt và thanh toán bởi Traveloka|Prepaid|Booked and Payable by\s*(?:\|\s*)?Traveloka/i.test(text)) {
      data.payment_status = "Prepaid";
    } else if (/Thanh toán tại khách sạn|Pay at hotel|Hotel Collect/i.test(text)) {
      data.payment_status = "Postpaid";
    }


  } else {
    // --- AGODA (LOGIC CŨ + FIX MỚI) ---

    // 1. Tổng tiền
    data.total_price = findValueNearKey(text, /(Reference sell rate|Giá bán tham khảo)/i);

    // 2. Net Rate
    data.net_rate = findValueNearKey(text, /(Net rate|Giá thực tế)/i);

    // 3. Commission
    data.commission = findValueNearKey(text, /(Commission|Tiền hoa hồng)/i);

    // 4. Khoản bù trừ (Surcharge) - FIX LỖI
    var surMatch = text.match(/(?:Khoản bù trừ|Surcharge)[^0-9-]*((?:-|−)[\d,.]+)/i);
    if (surMatch) {
        data.surcharge = surMatch[1];
    } else {
        data.surcharge = findValueNearKey(text, /(Khoản bù trù|Surcharge)/i);
    }

    // 5. Chương trình khác
    var otherMatch = text.match(/(?:Chương trình khác|Other programs)[^0-9-]*((?:-|−)[\d,.]+)/i);
    if (otherMatch) {
        data.other_programs = otherMatch[1];
    } else {
        data.other_programs = findValueNearKey(text, /(Chương trình khác|Other programs)/i);
    }


    // 6. Vé ăn sáng
    if (/(Breakfast|Ăn sáng|Kèm bữa sáng|BF Included)/i.test(text)) {
      data.has_breakfast = "Có";
    }
  }


  return data;
}



function findValueNearKey(text, keyRegex) {
  var match = text.match(keyRegex);
  if (!match) return "0";

  var snippet = text.substring(match.index, match.index + 400);
  var moneyRegex = /((?:-|−)?[\d,.]+)/g;
  var numbers = snippet.match(moneyRegex);

  if (numbers) {
    for (var i = 0; i < numbers.length; i++) {
      var num = numbers[i];
      if ((num.length > 3 && (num.includes(',') || num.includes('.'))) || num.length > 5) {
        return num;
      }
    }
  }
  return "0";
}




