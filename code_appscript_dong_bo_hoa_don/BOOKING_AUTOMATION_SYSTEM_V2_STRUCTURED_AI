/**
 * Lấy các dòng đang được bôi đen và đẩy lên Supabase
 */
function syncSelectedRowsToSupabase() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getActiveSheet();
  var ui = SpreadsheetApp.getUi();
  
  if (sheet.getName() !== CONFIG.SHEET_DATA_NAME) {
    ui.alert('❌ Lỗi', 'Vui lòng chọn các dòng bên trong sheet: ' + CONFIG.SHEET_DATA_NAME, ui.ButtonSet.OK);
    return;
  }

  var range = sheet.getActiveRange();
  var startRow = range.getRow();
  var numRows = range.getNumRows();

  if (startRow <= 1) {
    ui.alert('❌ Lỗi', 'Vui lòng không chọn dòng tiêu đề (dòng 1). Hãy bôi đen các dòng chứa mã booking cần đồng bộ.', ui.ButtonSet.OK);
    return;
  }

  var countSuccess = 0;
  for (var i = 0; i < numRows; i++) {
    var row = startRow + i;
    var rowData = sheet.getRange(row, 1, 1, 21).getValues()[0];
    
    var bookingCode = String(rowData[3] || '').trim(); // Cột D = Mã BK
    if (!bookingCode) continue;

    var rowCheckIn = parseDateToISO_(rowData[5]); // Cột F = Check-in
    var rowCheckOut = parseDateToISO_(rowData[6]); // Cột G = Check-out
    var supabaseBookingCode = buildSupabaseBookingCode_(bookingCode, rowCheckIn, row);
    
    var now = new Date().toISOString();
    var payload = {
      booking_code: supabaseBookingCode,
      platform: String(rowData[1] || ''),
      facility_name: String(rowData[2] || ''),
      guest_name: String(rowData[4] || ''),
      room_type: String(rowData[7] || ''),
      room_quantity: parseInt(rowData[8], 10) || 1,
      guest_count: String(rowData[9] || ''),
      total_amount: parseFloat(cleanMoneyString(String(rowData[10] || '0'))) || 0,
      commission_amount: parseFloat(cleanMoneyString(String(rowData[11] || '0'))) || 0,
      transfer_amount: parseFloat(cleanMoneyString(String(rowData[12] || '0'))) || 0,
      other_programs: String(rowData[13] || ''),
      net_amount: parseFloat(cleanMoneyString(String(rowData[14] || '0'))) || 0,
      breakfast_status: String(rowData[15] || ''),
      payment_status: String(rowData[16] || ''),
      notes: appendOriginalCodeNote_(String(rowData[17] || ''), bookingCode),
      status: String(rowData[18] || 'Pending'),
      updated_at: now
    };

    var emailDate = parseDateToISO_(rowData[0]);
    if (emailDate) {
      payload.email_date = emailDate;
      payload.created_at = emailDate;
    } else {
      payload.email_date = now;
      payload.created_at = now;
    }

    if (rowCheckIn) payload.check_in = rowCheckIn;
    if (rowCheckOut) payload.check_out = rowCheckOut;

    var url = SUPABASE_CONFIG.URL + '/rest/v1/' + SUPABASE_CONFIG.TABLE + '?on_conflict=booking_code';
    var res = UrlFetchApp.fetch(url, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_CONFIG.API_KEY,
        'Authorization': 'Bearer ' + SUPABASE_CONFIG.API_KEY,
        'Content-Type': 'application/json',
        'Prefer': 'resolution=merge-duplicates,return=minimal'
      },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    if (res.getResponseCode() >= 200 && res.getResponseCode() < 300) {
      countSuccess++;
    }
  }

  ui.alert('✅ Thành công', 'Đã gửi ' + countSuccess + '/' + numRows + ' dòng đang chọn lên Database.', ui.ButtonSet.OK);
}

/**
 * Trigger handler chính: Bắt sự kiện khi có dòng bị sửa chữa.
 */
function onSheetEditSync(e) {
  try {
    // Nếu chạy thủ công mà không có event (e), thoát luôn tránh lỗi
    if (!e || !e.range) return;

    var sheet = e.range.getSheet();
    var sheetName = sheet.getName();

    // Chỉ chạy khi sửa ở sheet dữ liệu chính
    if (sheetName !== CONFIG.SHEET_DATA_NAME) return;

    var row = e.range.getRow();
    // Bỏ qua nếu sửa ở dòng tiêu đề (header)
    if (row <= 1) return;

    // Đọc toàn bộ dữ liệu của dòng vừa sửa (21 cột: A-U)
    var rowData = sheet.getRange(row, 1, 1, 21).getValues()[0];
    var bookingCode = String(rowData[3] || '').trim(); // Cột D = Mã BK

    // Bỏ qua nếu dòng này chưa có mã booking hoặc chưa có Ngày Check-in
    // (Bảo vệ: Tránh tạo ra các bản ghi lỗi chứa đuôi _ROW_ khi người dùng đang gõ tay từng ô)
    if (!bookingCode || !rowData[5]) return;

    var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);

    // Tìm ngày gốc (xử lý trường hợp booking bị tách dòng làm nhiều đêm)
    var originalDates = findOriginalDates_(sheet, bookingCode);

    // Build payload để gửi sang Supabase
    var now = new Date().toISOString();
    var rowCheckIn = parseDateToISO_(rowData[5]); // Cột F = Check-in của chính dòng này
    var rowCheckOut = parseDateToISO_(rowData[6]); // Cột G = Check-out của chính dòng này
    var supabaseBookingCode = buildSupabaseBookingCode_(bookingCode, rowCheckIn, row);
    var payload = {
      booking_code: supabaseBookingCode,
      platform: String(rowData[1] || ''),
      facility_name: String(rowData[2] || ''),
      guest_name: String(rowData[4] || ''),
      room_type: String(rowData[7] || ''),
      room_quantity: parseInt(rowData[8], 10) || 1,
      guest_count: String(rowData[9] || ''),
      total_amount: parseFloat(cleanMoneyString(String(rowData[10] || '0'))) || 0,
      commission_amount: parseFloat(cleanMoneyString(String(rowData[11] || '0'))) || 0,
      transfer_amount: parseFloat(cleanMoneyString(String(rowData[12] || '0'))) || 0,
      other_programs: String(rowData[13] || ''),
      net_amount: parseFloat(cleanMoneyString(String(rowData[14] || '0'))) || 0,
      breakfast_status: String(rowData[15] || ''),
      payment_status: String(rowData[16] || ''),
      notes: appendOriginalCodeNote_(String(rowData[17] || ''), bookingCode),
      status: String(rowData[18] || 'Pending'),
      updated_at: now
    };

    // Thêm ngày đặt (cột A = email date)
    var emailDate = parseDateToISO_(rowData[0]);
    if (emailDate) {
      payload.email_date = emailDate;
      payload.created_at = emailDate;
    } else {
      payload.email_date = now;
      payload.created_at = now;
    }

    // Dùng ngày của chính dòng hiện tại để mỗi dòng Sheet là 1 booking riêng
    if (rowCheckIn) payload.check_in = rowCheckIn;
    if (rowCheckOut) payload.check_out = rowCheckOut;

    // Gửi REST API UPSERT lên Supabase
    var url = SUPABASE_CONFIG.URL + '/rest/v1/' + SUPABASE_CONFIG.TABLE + '?on_conflict=booking_code';
    var res = UrlFetchApp.fetch(url, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_CONFIG.API_KEY,
        'Authorization': 'Bearer ' + SUPABASE_CONFIG.API_KEY,
        'Content-Type': 'application/json',
        'Prefer': 'resolution=merge-duplicates,return=minimal' // Quan trọng: return=minimal để tránh timeout
      },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    var code = res.getResponseCode();
    if (code >= 200 && code < 300) {
      logToSheet(ss, '📝 onEdit SYNC OK: ' + supabaseBookingCode + ' (gốc: ' + bookingCode + ', dòng ' + row + ')');
    } else {
      logToSheet(ss, '❌ onEdit SYNC FAIL: ' + supabaseBookingCode + ' HTTP ' + code + ' - ' + res.getContentText());
    }

  } catch (err) {
    try {
      var ss2 = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
      logToSheet(ss2, '❌ onEdit ERROR: ' + err.toString());
    } catch (e2) {
      Logger.log('onSheetEditSync error: ' + err.toString());
    }
  }
}

/**
 * ✅ Wrapper tương thích ngược cho trigger cũ.
 */
function onSheetEdit_(e) {
  return onSheetEditSync(e);
}

/**
 * Tìm ngày check-in đầu tiên và check-out cuối cùng của cùng booking code.
 */
function findOriginalDates_(sheet, bookingCode) {
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return { firstCheckIn: null, lastCheckOut: null };

  var data = sheet.getRange(2, 4, lastRow - 1, 4).getValues(); // D, E, F, G

  var firstCheckIn = null;
  var lastCheckOut = null;

  for (var i = 0; i < data.length; i++) {
    var code = String(data[i][0] || '').trim();
    if (code === bookingCode) {
      var ci = data[i][2]; // F
      var co = data[i][3]; // G

      if (!firstCheckIn && ci) firstCheckIn = ci;
      if (co) lastCheckOut = co;
    }
  }

  return {
    firstCheckIn: firstCheckIn,
    lastCheckOut: lastCheckOut
  };
}

