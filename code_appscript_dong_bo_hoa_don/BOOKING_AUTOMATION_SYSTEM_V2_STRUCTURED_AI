function applyDuplicateBookingHighlight_(sheet) {
  if (!sheet) return;

  var range = sheet.getRange(2, 1, Math.max(sheet.getMaxRows() - 1, 1), 21); // A2:U
  var formula = '=AND($D2<>"",COUNTIF($D:$D,$D2)>1)';

  var rules = sheet.getConditionalFormatRules() || [];
  var keptRules = [];
  for (var i = 0; i < rules.length; i++) {
    var rule = rules[i];
    var bc = rule.getBooleanCondition && rule.getBooleanCondition();
    var keep = true;
    if (bc && bc.getCriteriaType && bc.getCriteriaType() === SpreadsheetApp.BooleanCriteria.CUSTOM_FORMULA) {
      var values = bc.getCriteriaValues ? bc.getCriteriaValues() : [];
      if (values && values[0] === formula) keep = false;
    }
    if (keep) keptRules.push(rule);
  }

  var newRule = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied(formula)
    .setBackground('#e5e7eb')
    .setRanges([range])
    .build();

  keptRules.push(newRule);
  sheet.setConditionalFormatRules(keptRules);

  // Tô trực tiếp một lần để thấy ngay trên sheet hiện tại.
  paintDuplicateBookingRows_(sheet);
}

function paintDuplicateBookingRows_(sheet) {
  if (!sheet) return;
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  var numRows = lastRow - 1;
  var idValues = sheet.getRange(2, 4, numRows, 1).getDisplayValues(); // D: Mã BK
  var counts = {};

  for (var i = 0; i < idValues.length; i++) {
    var id = idValues[i][0] ? idValues[i][0].toString().trim() : "";
    if (id) counts[id] = (counts[id] || 0) + 1;
  }

  var backgrounds = [];
  for (var r = 0; r < idValues.length; r++) {
    var rowId = idValues[r][0] ? idValues[r][0].toString().trim() : "";
    var color = (rowId && counts[rowId] > 1) ? "#e5e7eb" : null;
    var rowColors = [];
    for (var c = 0; c < 21; c++) rowColors.push(color);
    backgrounds.push(rowColors);
  }

  sheet.getRange(2, 1, numRows, 21).setBackgrounds(backgrounds);
}

