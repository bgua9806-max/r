/**
 * Parse ngày từ nhiều format sang ISO string cho Supabase
 */
function buildSupabaseBookingCode_(bookingCode, checkInIso, rowNumber) {
  var base = String(bookingCode || '').trim();
  if (!base) return '';

  var dateKey = '';
  if (checkInIso) {
    dateKey = String(checkInIso).slice(0, 10);
  }

  if (dateKey) return base + '_' + dateKey;
  if (rowNumber) return base + '_ROW_' + rowNumber;
  return base;
}

function appendOriginalCodeNote_(notes, originalCode) {
  var cleanNotes = String(notes || '').trim();
  var prefix = 'Mã gốc: ' + String(originalCode || '').trim();
  if (!cleanNotes) return prefix;
  if (cleanNotes.indexOf(prefix) !== -1) return cleanNotes;
  return prefix + ' | ' + cleanNotes;
}

function parseDateToISO_(dateValue) {
  if (!dateValue) return null;

  // Nếu đã là Date object
  if (Object.prototype.toString.call(dateValue) === '[object Date]' && !isNaN(dateValue.getTime())) {
    return dateValue.toISOString();
  }

  var s = dateValue.toString().trim();

  // Format dd/MM/yyyy
  var m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (m) {
    return new Date(parseInt(m[3]), parseInt(m[2]) - 1, parseInt(m[1])).toISOString();
  }

  // Format yyyy-MM-dd
  m = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (m) {
    return new Date(parseInt(m[1]), parseInt(m[2]) - 1, parseInt(m[3])).toISOString();
  }

  // Fallback
  var d = new Date(s);
  return !isNaN(d.getTime()) ? d.toISOString() : null;
}

/**
 * Đồng bộ thủ công: Quét toàn bộ sheet và gửi lên Supabase
 * Chạy 1 lần nếu cần sync lại dữ liệu cũ
 */
function manualSyncAllToSupabase() {
  var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
  var sheet = ss.getSheetByName(CONFIG.SHEET_DATA_NAME);
  if (!sheet) { logToSheet(ss, '❌ Không tìm thấy sheet ' + CONFIG.SHEET_DATA_NAME); return; }

  var data = sheet.getDataRange().getValues();
  var synced = 0;
  var skipped = 0;

  for (var i = 1; i < data.length; i++) {
    var row = data[i];
    var bookingCode = (row[3] || '').toString().trim();
    if (!bookingCode) { skipped++; continue; }

    var bookingData = {
      booking_id: bookingCode,
      platform: row[1] || '',
      hotel_name: row[2] || '',
      guest_name: row[4] || '',
      check_in: row[5],
      check_out: row[6],
      room_type: row[7] || '',
      rooms: row[8] || 1,
      occupancy: row[9] || '',
      total_price: row[10] || '0',
      commission: row[11] || '0',
      surcharge: row[12] || '0',
      other_programs: row[13] || '',
      net_rate: row[14] || '0',
      breakfast: row[15] || '',
      payment_status: row[16] || '',
      special_requests: row[17] || ''
    };

    syncBookingToSupabase_(bookingData, null);
    synced++;

    // Tránh rate limit
    if (synced % 50 === 0) {
      Utilities.sleep(1000);
      logToSheet(ss, '🔄 Manual sync progress: ' + synced + '/' + (data.length - 1));
    }
  }

  logToSheet(ss, '✅ Manual sync hoàn tất: ' + synced + ' đơn đã sync, ' + skipped + ' bỏ qua.');
}


