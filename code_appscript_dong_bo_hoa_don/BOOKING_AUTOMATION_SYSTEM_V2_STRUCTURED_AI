/**
 * ✅ SETUP V2: Chạy 1 lần sau khi dán code lên Apps Script.
 * Hàm này kiểm tra thiếu gì thì tạo cái đó, cái nào có rồi thì bỏ qua.
 *
 * Tự động khởi tạo:
 * - Sheet dữ liệu Booking_Master_DB_Final_V20
 * - Sheet System_Logs
 * - Sheet Platform_Config
 * - Sheet AI_Test_Results
 * - Gmail labels: Booking/Processed, Booking/Cancelled, Test Booking
 * - Time trigger chạy mainAutoProcess1 mỗi 5 phút nếu chưa có
 */
function setupBookingAutomationV2() {
  var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
  var setupLogs = [];

  setupLogs.push(ensureCoreSheet_(ss, CONFIG.SHEET_DATA_NAME));
  setupLogs.push(ensureLogSheet_(ss));
  setupLogs.push(ensurePlatformConfigSheet_(ss));
  setupLogs.push(ensureTestResultSheet_(ss));

  setupLogs.push(ensureGmailLabel_(CONFIG.LABEL_PROCESSED));
  setupLogs.push(ensureGmailLabel_(CONFIG.LABEL_CANCELLED));
  setupLogs.push(ensureGmailLabel_(CONFIG.TEST_LABEL_NAME));

  setupLogs.push(ensureTimeTrigger_("mainAutoProcess1", 5));

  var logSheet = getOrCreateSheet(ss, CONFIG.SHEET_LOG_NAME);
  logSheet.appendRow([new Date(), "✅ SETUP V2 HOÀN TẤT:\n" + setupLogs.join("\n")]);
}

