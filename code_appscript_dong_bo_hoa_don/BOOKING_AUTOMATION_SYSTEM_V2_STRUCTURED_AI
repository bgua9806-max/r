/**
 * ✅ V23: Xác định platform từ email hủy
 */
function detectCancellationPlatform(subject, fromEmail) {
  if (subject.indexOf("Agoda") > -1) return "Agoda";
  if (subject.indexOf("Cancellation request accepted") > -1) return "Trip.com";
  if (subject.indexOf("Expedia") > -1) return "Expedia";
  if (fromEmail.indexOf("airbnb.com") > -1) return "Airbnb";
  return "Unknown";
}



/**
 * ✅ V23: Trích xuất Booking ID từ email hủy
 */
function extractCancelBookingId(message, subject, platform) {
  var bookingId = null;

  if (platform === "Agoda") {
    var agodaMatch = subject.match(/Agoda Booking ID\s*(\d+)/i);
    if (agodaMatch) bookingId = agodaMatch[1];

  } else if (platform === "Trip.com") {
    var tripMatch = subject.match(/(?:booking no\.?#?|#)(\d{10,20})/i);
    if (tripMatch) bookingId = tripMatch[1];

  } else if (platform === "Expedia") {
    var body = getDeepCleanBody(message);
    var expediaMatch = body.match(/(?:Mã đặt phòng|Itinerary)[:\s]*(\d{8,15})/i);
    if (expediaMatch) bookingId = expediaMatch[1];

  } else if (platform === "Airbnb") {
    var airbnbMatch = subject.match(/(?:Lượt đặt phòng|Reservation)\s*([A-Z0-9]{8,12})/i);
    if (airbnbMatch) bookingId = airbnbMatch[1];
  }

  return bookingId ? bookingId.trim() : null;
}



/**
 * ✅ V23: Cập nhật trạng thái booking thành CANCEL
 */
function updateBookingStatusToCancel(sheet, bookingId, cancelDate, ss) {
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return false;

  var bookingIds = sheet.getRange(2, 4, lastRow - 1, 1).getValues();
  var cancelDateValue = (Object.prototype.toString.call(cancelDate) === '[object Date]')
    ? Utilities.formatDate(cancelDate, Session.getScriptTimeZone(), "dd/MM/yyyy")
    : cancelDate;
  var updatedCount = 0;

  for (var i = 0; i < bookingIds.length; i++) {
    var currentId = bookingIds[i][0] ? bookingIds[i][0].toString().trim() : "";

    if (currentId === bookingId.toString().trim()) {
      var rowIndex = i + 2;
      var currentStatus = sheet.getRange(rowIndex, 19).getValue();

      if (currentStatus !== "CANCEL") {
        sheet.getRange(rowIndex, 19).setValue("CANCEL");      // S: Trạng Thái
        sheet.getRange(rowIndex, 21).setValue(cancelDateValue); // U: DATE CANCELLED
        updatedCount++;
      }
    }
  }

  if (updatedCount > 0 && ss) {
    logToSheet(ss, "🚫 Đã cập nhật hủy " + updatedCount + " dòng cho Mã BK: " + bookingId);
  }

  return updatedCount > 0;
}



