function processDriveBookings(sheetData, existingIds, ss) {
  var pendingFolderId = String(CONFIG.DRIVE_FOLDER_PENDING || '').trim();
  var doneFolderId = String(CONFIG.DRIVE_FOLDER_DONE || '').trim();
  
  if (!pendingFolderId || !doneFolderId || pendingFolderId === 'ĐIỀN_ID_THƯ_MỤC_PENDING_VÀO_ĐÂY') {
    return;
  }
  
  try {
    var pendingFolder = DriveApp.getFolderById(pendingFolderId);
    var doneFolder = DriveApp.getFolderById(doneFolderId);
    
    var files = pendingFolder.getFilesByType(MimeType.PDF);
    var processedCount = 0;
    var cancelledCount = 0;
    
    if (files.hasNext()) {
      logToSheet(ss, '📂 [DRIVE] Bắt đầu quét thư mục PDF: ' + pendingFolder.getName());
    } else {
      logToSheet(ss, '📂 [DRIVE] Thư mục hiện tại đang trống, không có file PDF nào.');
    }
    
    while (files.hasNext() && processedCount < CONFIG.DRIVE_BATCH_SIZE) {
      var file = files.next();
      var fileName = file.getName();
      
      logToSheet(ss, '📄 [DRIVE] Đang xử lý file: ' + fileName);
      
      // 1. Extract Text
      var plainText = extractTextFromPdf_(file.getId());
      if (!plainText || plainText.length < 50) {
        logToSheet(ss, '❌ [DRIVE] Không đọc được chữ từ file (hoặc quá ngắn): ' + fileName);
        continue;
      }
      
      // ═══════════════════════════════════════════════════════════
      // 1.5. KIỂM TRA ĐƠN HỦY (Booking.com)
      // ═══════════════════════════════════════════════════════════
      var isCancelled = /đã\s*hủy|cancelled|cancellation|hủy\s*đặt\s*phòng|booking\s*was\s*cancelled/i.test(plainText);
      if (isCancelled) {
        var cancelId = quickFindID(plainText, fileName);
        if (cancelId) {
          var cancelDate = new Date();
          var updated = updateBookingStatusToCancel(sheetData, cancelId, cancelDate, ss);
          if (updated) {
            syncCancellationToSupabase_(cancelId, cancelDate.toISOString(), ss);
            logToSheet(ss, '🚫 [DRIVE] ĐƠN HỦY! Đã MAP mã ' + cancelId + ' -> CANCEL + đồng bộ Supabase');
            cancelledCount++;
          } else {
            logToSheet(ss, '⚠️ [DRIVE] ĐƠN HỦY nhưng không tìm thấy mã ' + cancelId + ' trong Sheet.');
          }
          file.moveTo(doneFolder);
          processedCount++;
        } else {
          logToSheet(ss, '⚠️ [DRIVE] Phát hiện file HỦY nhưng không tìm được Mã Booking: ' + fileName);
        }
        continue;
      }
      
      // ═══════════════════════════════════════════════════════════
      // 2. KIỂM TRA TRÙNG ID
      // ═══════════════════════════════════════════════════════════
      var quickID = quickFindID(plainText, fileName);
      if (quickID && existingIds.includes(quickID)) {
        logToSheet(ss, '⚠️ [DRIVE] Bỏ qua - Đã tồn tại mã (Duplicate): ' + quickID);
        file.moveTo(doneFolder);
        processedCount++;
        continue;
      }
      
      // ═══════════════════════════════════════════════════════════
      // 3. PHÂN TÍCH QUA AI (Force Booking.com)
      // ═══════════════════════════════════════════════════════════
      var platform = 'Booking.com';
      var bookingMarkdown = normalizeBookingComPdfToMarkdown_(plainText, fileName);
      var smartContext = getHeadAndTail(bookingMarkdown);
      var hardData = scanDataByPlatform(smartContext, platform);
      var finalData = callOpenAI(smartContext, hardData, platform);
      
      if (!finalData || !finalData.booking_id) {
        logToSheet(ss, '❌ [DRIVE] AI không nhận diện được booking từ file: ' + fileName);
        continue;
      }
      
      // Force platform
      finalData.platform = 'Booking.com';
      
      // Làm sạch số tiền
      finalData.total_price = cleanMoneyString(finalData.total_price);
      finalData.net_rate = cleanMoneyString(finalData.net_rate);
      finalData.commission = cleanMoneyString(finalData.commission);
      finalData.surcharge = cleanMoneyString(finalData.surcharge);
      finalData.other_programs = cleanMoneyString(finalData.other_programs);
      
      // Format tên phòng
      var finalRoomType = finalData.room_type || '';
      var roomCodeMatch = finalRoomType.match(/(\d+G\s*\d+M\d+)/i);
      if (!roomCodeMatch) {
        roomCodeMatch = finalRoomType.match(/\(([A-Z0-9]{3,})\)/i);
      }
      if (roomCodeMatch) {
        var roomCode = roomCodeMatch[1].replace(/\s+/g, '').toUpperCase();
        var roomQty = finalData.rooms || 1;
        finalRoomType = roomCode + ' (x' + roomQty + ')';
      }
      
      // ═══════════════════════════════════════════════════════════
      // 4. GHI VÀO GOOGLE SHEET (21 cột đúng cấu trúc)
      // Booking.com PDF: ưu tiên tách từng unit/phòng trong file
      // ═══════════════════════════════════════════════════════════
      var currentId = finalData.booking_id.toString().trim();
      if (existingIds.includes(currentId)) {
        logToSheet(ss, '⚠️ [DRIVE] Bỏ qua ID trùng (AI Check): ' + currentId);
        file.moveTo(doneFolder);
        processedCount++;
        continue;
      }
      
      var unitRates = CONFIG.SPLIT_BOOKINGCOM_BY_UNIT ? extractBookingComUnitRates(bookingMarkdown, finalData) : [];
      if ((!unitRates || unitRates.length === 0) && CONFIG.SPLIT_BOOKINGCOM_BY_UNIT) {
        unitRates = buildBookingComFallbackRoomNightRates_(finalData, finalRoomType);
        if (unitRates && unitRates.length > 0) {
          logToSheet(ss, 'ℹ️ [DRIVE] Không bắt được block chi tiết, dùng fallback tách ' + unitRates.length + ' dòng theo SL phòng × số đêm cho mã: ' + currentId);
        }
      }
      var rowsToWrite = [];
      if (unitRates && unitRates.length > 0) {
        for (var ur = 0; ur < unitRates.length; ur++) {
          var unitRoomType = formatBookingComRoomType_(unitRates[ur].room_type, unitRates[ur].rooms || 1);
          rowsToWrite.push([
            new Date(),
            'Booking.com',
            finalData.hotel_name || '',
            finalData.booking_id || '',
            finalData.guest_name || '',
            parseDateToSheetFormat(unitRates[ur].check_in),
            parseDateToSheetFormat(unitRates[ur].check_out),
            unitRoomType,
            unitRates[ur].rooms || 1,
            finalData.occupancy || '',
            unitRates[ur].gross || 0,
            unitRates[ur].commission || 0,
            unitRates[ur].surcharge || 0,
            unitRates[ur].other_programs || 0,
            unitRates[ur].net_rate || 0,
            unitRates[ur].breakfast || finalData.breakfast || 'Không',
            finalData.payment_status || '',
            finalData.special_requests || '',
            'SUCCESS',
            '',
            ''
          ]);
        }
        logToSheet(ss, '✅ [DRIVE] Booking.com đã tách ' + unitRates.length + ' dòng unit/phòng cho mã: ' + currentId);
      } else {
        rowsToWrite.push([
          new Date(),                                        // A: Ngày Email
          'Booking.com',                                     // B: Platform
          finalData.hotel_name || '',                         // C: Văn Khách Sạn
          finalData.booking_id || '',                         // D: Mã BK
          finalData.guest_name || '',                         // E: Tên Khách
          parseDateToSheetFormat(finalData.check_in),         // F: Check-in
          parseDateToSheetFormat(finalData.check_out),        // G: Check-out
          finalRoomType,                                      // H: Loại Phòng
          finalData.rooms || 1,                               // I: SL Phòng
          finalData.occupancy || '',                           // J: Số Khách
          finalData.total_price || 0,                          // K: Tổng Tiền
          finalData.commission || 0,                           // L: Hoa Hồng
          finalData.surcharge || 0,                            // M: Khoản Bù Trừ
          finalData.other_programs || 0,                       // N: Chương Trình Khác
          finalData.net_rate || 0,                              // O: Thực Nhận
          finalData.breakfast || 'Không',                      // P: Ăn Sáng
          finalData.payment_status || '',                       // Q: Thanh Toán
          finalData.special_requests || '',                     // R: Yêu Cầu Đặc Biệt
          'SUCCESS',                                           // S: Status
          '',                                                  // T: Xếp Phòng
          ''                                                   // U: Date Cancelled
        ]);
      }
      
      for (var rw = 0; rw < rowsToWrite.length; rw++) {
        sheetData.appendRow(rowsToWrite[rw]);
      }
      existingIds.push(currentId);
      logToSheet(ss, '✅ [DRIVE] Đã lưu: ' + currentId + ' (' + finalData.guest_name + ') - ' + rowsToWrite.length + ' dòng');
      
      // ═══════════════════════════════════════════════════════════
      // 5. ĐỒNG BỘ LÊN SUPABASE
      // ═══════════════════════════════════════════════════════════
      if (unitRates && unitRates.length > 0) {
        for (var si = 0; si < unitRates.length; si++) {
          var syncData = Object.assign({}, finalData);
          syncData.check_in = unitRates[si].check_in;
          syncData.check_out = unitRates[si].check_out;
          syncData.room_type = formatBookingComRoomType_(unitRates[si].room_type, unitRates[si].rooms || 1);
          syncData.rooms = unitRates[si].rooms || 1;
          syncData.total_price = unitRates[si].gross;
