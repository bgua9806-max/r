  var url = SUPABASE_CONFIG.URL + '/rest/v1/' + SUPABASE_CONFIG.TABLE + '?on_conflict=booking_code';
  var res = UrlFetchApp.fetch(url, {
    method: 'POST',
    headers: {
      'apikey': SUPABASE_CONFIG.API_KEY,
      'Authorization': 'Bearer ' + SUPABASE_CONFIG.API_KEY,
      'Content-Type': 'application/json',
      'Prefer': 'resolution=merge-duplicates,return=minimal'
    },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  var code = res.getResponseCode();
  if (code >= 200 && code < 300) {
    logToSheet(ss, '✅ [SAMPLE] Gửi thành công! Mã: ' + testCode);
    logToSheet(ss, '📋 [SAMPLE] Chi tiết: ' + payload.guest_name + ' | ' + payload.room_type + ' | ' + payload.total_amount + ' VND');
  } else {
    logToSheet(ss, '❌ [SAMPLE] Gửi thất bại! HTTP ' + code + ' - ' + res.getContentText());
  }
}

