  ensureTimeTrigger_("mainAutoProcess1", 5);
  logToSheet(SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID), "✅ Đã reset trigger mainAutoProcess1 mỗi 5 phút.");
}

function ensureCoreSheet_(ss, sheetName) {
  var existed = !!ss.getSheetByName(sheetName);
  var sheet = getOrCreateSheet(ss, sheetName);
  if (!existed) return "CREATED sheet: " + sheetName;

  // Nếu sheet đã có nhưng trống, bổ sung header an toàn.
  if (sheet.getLastRow() === 0) {
    sheet.appendRow([
      "Ngày Email", "Platform", "Tên Khách Sạn", "Mã BK", "Tên Khách",
      "Check-in", "Check-out", "Loại Phòng", "SL Phòng", "Số Khách",
      "Tổng Tiền (Gross)", "Hoa Hồng (Comm)", "Khoản Bù Trù", "Chương Trình Khác", "Thực Nhận (Net)",
      "Ăn Sáng", "Thanh Toán", "Yêu Cầu Đặc Biệt", "Trạng Thái", "Xếp Phòng", "DATE CANCELLED"
    ]);
    sheet.setFrozenRows(1);
    applyDuplicateBookingHighlight_(sheet);
    return "REPAIRED empty sheet header: " + sheetName;
  }
  applyDuplicateBookingHighlight_(sheet);
  return "OK sheet exists: " + sheetName;
}

function ensureLogSheet_(ss) {
  var existed = !!ss.getSheetByName(CONFIG.SHEET_LOG_NAME);
  var sheet = getOrCreateSheet(ss, CONFIG.SHEET_LOG_NAME);
  return existed ? "OK sheet exists: " + CONFIG.SHEET_LOG_NAME : "CREATED sheet: " + CONFIG.SHEET_LOG_NAME;
}

function ensurePlatformConfigSheet_(ss) {
  var existed = !!ss.getSheetByName(CONFIG.SHEET_CONFIG_NAME);
  var sheet = getOrCreateConfigSheet(ss);

  // Nếu sheet mới tạo hoặc chỉ có header → điền đủ 5 platform mặc định
  if (sheet.getLastRow() < 2) {
    var defaultPlatforms = [
      ["Agoda",     "ON", "",                          "Agoda Booking ID && CONFIRMED",              "Agoda Booking ID && CANCELLED",           "no-reply@agoda.com"],
      ["Expedia",   "ON", "",                          "Expedia - Đặt phòng mới",                   "Expedia - Hủy đặt phòng",                ""],
      ["Trip.com",  "ON", "auto_reservation@trip.com", "Action required - New booking received || Trip.com - Thông báo đơn đặt mới || Booking no.", "Cancellation request accepted", "auto_reservation@trip.com"],
      ["Airbnb",    "ON", "automated@airbnb.com",    "Đã xác nhận đặt phòng",                     "Đã hủy",                                 "automated@airbnb.com"],
      ["Traveloka", "ON", "hotel@traveloka.com",       "CONFIRMED - Traveloka Itinerary",            "",                                        ""]
    ];

    for (var i = 0; i < defaultPlatforms.length; i++) {
      sheet.appendRow(defaultPlatforms[i]);
    }
    return "REPAIRED Platform_Config: added " + defaultPlatforms.length + " default platforms";
  }
  return existed ? "OK sheet exists: " + CONFIG.SHEET_CONFIG_NAME : "CREATED sheet: " + CONFIG.SHEET_CONFIG_NAME;
}

function ensureTestResultSheet_(ss) {
  var existed = !!ss.getSheetByName(CONFIG.TEST_RESULT_SHEET_NAME);
  getOrCreateTestResultSheet(ss);
  return existed ? "OK sheet exists: " + CONFIG.TEST_RESULT_SHEET_NAME : "CREATED sheet: " + CONFIG.TEST_RESULT_SHEET_NAME;
}

function ensureGmailLabel_(labelName) {
  if (!labelName) return "SKIP empty Gmail label";
  var label = GmailApp.getUserLabelByName(labelName);
  if (label) return "OK Gmail label exists: " + labelName;
  GmailApp.createLabel(labelName);
  return "CREATED Gmail label: " + labelName;
}

function ensureTimeTrigger_(handlerName, everyMinutes) {
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction && triggers[i].getHandlerFunction() === handlerName) {
      return "OK trigger exists: " + handlerName;
    }
  }

  ScriptApp.newTrigger(handlerName)
    .timeBased()
    .everyMinutes(everyMinutes || 5)
    .create();

  return "CREATED trigger: " + handlerName + " every " + (everyMinutes || 5) + " minutes";
}

function deleteTriggersByHandler_(handlerName) {
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction && triggers[i].getHandlerFunction() === handlerName) {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }
}


