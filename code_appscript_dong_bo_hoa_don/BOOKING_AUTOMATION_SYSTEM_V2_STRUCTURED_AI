/**
 * HAM CHINH DE KHOI PHUC - Chay thu cong khi he thong bi su co
 * 
 * CACH DUNG:
 *   1. Mo Apps Script Editor
 *   2. Chon ham "recoverMissedBookings" tu dropdown
 *   3. Nhan Run
 *   4. Kiem tra Sheet "System_Logs" de theo doi tien trinh
 *
 * MAC DINH: Quet lai 3 ngay gan nhat
 * NEU MUON THAY DOI: Sua bien RECOVERY_DAYS ben duoi
 */
function recoverMissedBookings() {
  var RECOVERY_DAYS = 3;
  var BATCH_SIZE = 50;
  var MAX_BATCHES = 4;

  try {
    var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);

    // 1. Doc config platform
    var platformConfigs = loadPlatformConfig(ss);
    if (platformConfigs.length === 0) {
      logToSheet(ss, "[RECOVERY] Khong co platform nao ON trong Platform_Config.");
      return;
    }

    // 2. Build query voi khoang thoi gian mo rong
    var searchQuery = buildRecoverySearchQuery(platformConfigs, RECOVERY_DAYS);
    logToSheet(ss, "========== BAT DAU RECOVERY ==========");
    logToSheet(ss, "[RECOVERY] Quet lai " + RECOVERY_DAYS + " ngay gan nhat");
    logToSheet(ss, "[RECOVERY] Query: " + searchQuery.substring(0, 200));
    logToSheet(ss, "======================================");

    // 3. Lay sheet du lieu + danh sach ID da co
    var sheetData = getOrCreateSheet(ss, CONFIG.SHEET_DATA_NAME);
    var existingIds = getExistingBookingIds(sheetData);
    logToSheet(ss, "[RECOVERY] Hien co " + existingIds.length + " booking trong Sheet.");

    // 4. Quet theo batch
    var totalProcessed = 0;
    var totalCancelled = 0;
    var totalSkippedDuplicate = 0;
    var totalThreads = 0;
    var totalEmails = 0;

    for (var batch = 0; batch < MAX_BATCHES; batch++) {
      var startIndex = batch * BATCH_SIZE;
      var threads;

      try {
        threads = GmailApp.search(searchQuery, startIndex, BATCH_SIZE);
      } catch (e) {
        logToSheet(ss, "[RECOVERY] Batch " + (batch + 1) + ": Loi tim email - " + e.toString());
        break;
      }

      if (threads.length === 0) {
        logToSheet(ss, "[RECOVERY] Batch " + (batch + 1) + ": Het email de quet.");
        break;
      }

      logToSheet(ss, "[RECOVERY] Batch " + (batch + 1) + "/" + MAX_BATCHES + ": Dang xu ly " + threads.length + " thread (tu #" + (startIndex + 1) + ")...");

      var batchResult = recoverBatch(threads, sheetData, existingIds, platformConfigs, ss);

      totalProcessed += batchResult.processed;
      totalCancelled += batchResult.cancelled;
      totalSkippedDuplicate += batchResult.skippedDuplicate;
      totalThreads += threads.length;
      totalEmails += batchResult.totalEmails;

      existingIds = getExistingBookingIds(sheetData);

      if (threads.length < BATCH_SIZE) break;

      Utilities.sleep(2000);
    }

    // 5. Bao cao tong hop
    logToSheet(ss, "========== RECOVERY HOAN THANH ==========");
    logToSheet(ss, "  Threads da quet: " + totalThreads);
    logToSheet(ss, "  Tong email da kiem tra: " + totalEmails);
    logToSheet(ss, "  Booking MOI da them: " + totalProcessed);
    logToSheet(ss, "  Booking HUY da xu ly: " + totalCancelled);
    logToSheet(ss, "  Email trung ID (bo qua): " + totalSkippedDuplicate);
    logToSheet(ss, "=========================================");

  } catch (e) {
    Logger.log("RECOVERY CRITICAL ERROR: " + e.toString());
    logToSheet(SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID), "[RECOVERY] LOI NGHIEM TRONG: " + e.toString());
  }
}



/**
 * Build Gmail Search Query cho Recovery (mo rong thoi gian)
 * Giong buildSearchQuery nhung dung newer_than:Xd thay vi newer_than:1d
 */
function buildRecoverySearchQuery(configs, days) {
  var parts = [];

  for (var i = 0; i < configs.length; i++) {
    var cfg = configs[i];

    if (cfg.bookingKeyword) {
      var bookingPart = buildSingleQueryPart(cfg.bookingKeyword, cfg.fromEmail);
      parts.push(bookingPart);
    }

    if (cfg.cancelKeyword) {
      var cancelFrom = cfg.cancelFrom || cfg.fromEmail;
      var cancelPart = buildSingleQueryPart(cfg.cancelKeyword, cancelFrom);
      parts.push(cancelPart);
    }
  }

  if (parts.length === 0) return "";

  return "(" + parts.join(" OR ") + ") -subject:Re: newer_than:" + days + "d";
}



/**
 * Xu ly 1 batch thread cho Recovery
 * Khac mainAutoProcess1: KHONG gioi han 30 phut
 */
function recoverBatch(threads, sheetData, existingIds, platformConfigs, ss) {
  var result = {processed: 0, cancelled: 0, skippedDuplicate: 0, totalEmails: 0};

  for (var i = 0; i < threads.length; i++) {
    var messages = threads[i].getMessages();
    result.totalEmails += messages.length;

    for (var j = 0; j < messages.length; j++) {
      var message = messages[j];
      var subject = message.getSubject();
      var fromEmail = message.getFrom();

      // KHONG kiem tra isEmailTooOld() - day la diem khac biet chinh

      // Kiem tra email huy
      if (isCancellationFromConfig(subject, fromEmail, platformConfigs)) {
        var cancelResult = processCancellationEmail(message, subject, fromEmail, sheetData, ss);
        if (cancelResult) {
          result.cancelled++;
          message.markRead();
        }
        continue;
      }

      // Xu ly booking moi
      var plainText = getDeepCleanBody(message);

      // Kiem tra trung ID nhanh
      var quickID = quickFindID(plainText, subject);
      if (quickID && existingIds.includes(quickID)) {
        result.skippedDuplicate++;
        continue;
      }

      // Xu ly chi tiet (dung chung core processor)
      var success = processSingleEmailCore(message, plainText, sheetData, existingIds, ss);
      if (success) {
        result.processed++;
      }
    }
  }

  return result;
}



