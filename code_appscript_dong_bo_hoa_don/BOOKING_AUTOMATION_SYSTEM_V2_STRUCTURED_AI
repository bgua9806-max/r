    }
    
    if (processedCount > 0 || cancelledCount > 0) {
      logToSheet(ss, '✅ [DRIVE] Tổng kết: ' + processedCount + ' file xử lý, ' + cancelledCount + ' đơn hủy.');
    }
    
  } catch (err) {
    logToSheet(ss, '❌ [DRIVE] Lỗi quét Drive: ' + err.toString());
  }
}

/**
 * Convert PDF thành Google Doc tạm thời để lấy Text (Cực chuẩn xác)
 */
function extractTextFromPdf_(fileId) {
  try {
    var token = ScriptApp.getOAuthToken();
    var url = 'https://www.googleapis.com/drive/v3/files/' + fileId + '/copy';
    
    var payload = {
      mimeType: 'application/vnd.google-apps.document'
    };
    
    var options = {
      method: 'POST',
      headers: {
        Authorization: 'Bearer ' + token,
        'Content-Type': 'application/json'
      },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    };
    
    var response = UrlFetchApp.fetch(url, options);
    var code = response.getResponseCode();
    
    if (code !== 200) {
      Logger.log('Error converting PDF: ' + response.getContentText());
      return null;
    }
    
    var docId = JSON.parse(response.getContentText()).id;
    var doc = DocumentApp.openById(docId);
    var text = doc.getBody().getText();
    
    // Xóa file tạm
    DriveApp.getFileById(docId).setTrashed(true);
    
    return text;
  } catch (e) {
    Logger.log('Exception in extractTextFromPdf_: ' + e.toString());
    return null;
  }
}



