function extractStructuredFields(cleanText, platform, subject) {
  var data = {};
  data.booking_id = extractByRegex(subject + " " + cleanText, /(?:Booking ID|M? s? ??t ph?ng|M? ??t ph?ng|Itinerary #|Booking Number|Trip\.com Booking ID|Traveloka Itinerary|M? s? h?nh tr?nh)[:\s|#-]*(\d{8,18})/i);
  if (!data.booking_id) data.booking_id = extractByRegex(subject + " " + cleanText, /(?:M? x?c nh?n|Confirmation code)[:\s|]*([A-Z0-9]{8,12})/i);
  data.property_id = extractByRegex(cleanText, /Property ID\s*(\d+)/i);
  data.hotel_name = extractByRegex(cleanText, /(?:Booking confirmation[^|]*\|\s*)+([^|]+?)\s*\(Property ID/i);
  if (!data.hotel_name) data.hotel_name = extractByRegex(cleanText, /\|\s*([^|]+?)\s*\(Property ID\s*\d+/i);
  data.city = extractByRegex(cleanText, /City[^|]*\|?\s*:?\s*([^|]+)/i);
  data.guest_first_name = extractByRegex(cleanText, /Customer First Name[^|]*\|\s*([^|]+)/i);
  data.guest_last_name = extractByRegex(cleanText, /Customer Last Name[^|]*\|\s*([^|]+)/i);
  data.guest_full_name = (data.guest_first_name || data.guest_last_name) ? ((data.guest_first_name || "") + " " + (data.guest_last_name || "")).replace(/\s+/g, " ").trim() : extractByRegex(cleanText, /(?:T?n:|Name:)\s*([^,|]+)/i);
  data.country = extractByRegex(cleanText, /Country of Residence[^|]*\|\s*([^|]+)/i);
  data.check_in = extractByRegex(cleanText, /Check-in[^|]*\|\s*([^|]+)/i);
  data.check_out = extractByRegex(cleanText, /Check-out[^|]*\|\s*([^|]+)/i);
  var roomBlock = cleanText.match(/Room Type[^|]*\|\s*No\. of Rooms[^|]*\|\s*Occupancy[^|]*\|\s*No\. of Extra Bed[^|]*\|\s*([^|]+)\|\s*([^|]+)\|\s*([^|]+)\|\s*([^|]+)/i);
  if (roomBlock) { data.room_type = roomBlock[1].trim(); data.rooms = roomBlock[2].trim(); data.occupancy = roomBlock[3].trim(); data.extra_bed = roomBlock[4].trim(); }
  else { data.room_type = extractByRegex(cleanText, /Room Type[^|]*\|\s*([^|]+)/i); data.rooms = extractByRegex(cleanText, /No\. of Rooms[^|]*\|\s*([^|]+)/i); data.occupancy = extractByRegex(cleanText, /Occupancy[^|]*\|\s*([^|]+)/i); }
  data.rate_plan = extractByRegex(cleanText, /(?:T?n ch?nh s?ch gi?|Rate plan|Rate Plan)[:\s]*([^|]+)/i);
  data.payment_status = extractByRegex(cleanText, /\|\s*(TR? TR??C|Tr? tr??c|Prepaid|Pay at hotel|Hotel Collect|Postpaid|Thanh to?n t?i kh?ch s?n)\s*\|/i);
  data.customer_notes = extractByRegex(cleanText, /Customer Notes[^|]*\|\s*([^|]+)/i);
  return data;
}

function extractByRegex(text, regex) { var match = text.match(regex); return match ? match[1].toString().trim() : ""; }

function safeMarkdownValue(value) {
  if (value === null || value === undefined) return "";
  return value.toString().replace(/\|/g, "/").replace(/\r?\n/g, " ").replace(/\s+/g, " ").trim();
}

