/**
 * Gửi 1 booking lên Supabase ota_orders.
 * ✅ OPTIMIZED: Dùng UPSERT 1 lần thay vì SELECT + INSERT/UPDATE (tránh timeout)
 * BẢO VỆ: Không ghi đè assigned_room, app_confirm_status, status nếu đã có.
 */
function syncBookingToSupabase_(bookingData, ss) {
  try {
    if (!bookingData || !bookingData.booking_id) return;

    var bookingCode = bookingData.booking_id.toString().trim();
    if (!bookingCode) return;

    var now = new Date().toISOString();

    // Parse dates trước để tạo mã booking riêng theo từng dòng/ngày
    var checkIn = parseDateToISO_(bookingData.check_in);
    var checkOut = parseDateToISO_(bookingData.check_out);
    var allowDuplicateBookingCode = bookingData.allow_duplicate_booking_code === true;
    var supabaseBookingCode = bookingData.supabase_booking_code
      ? bookingData.supabase_booking_code.toString().trim()
      : buildSupabaseBookingCode_(bookingCode, checkIn, null);
    var originalNotes = bookingData.special_requests || '';
    var syncNotes = 'Mã gốc: ' + bookingCode + (originalNotes ? ' | ' + originalNotes : '');

    // Build payload - CHỈ gửi các field an toàn
    var payload = {
      booking_code: supabaseBookingCode,
      platform: bookingData.platform || '',
      facility_name: bookingData.hotel_name || '',
      guest_name: bookingData.guest_name || '',
      guest_count: (bookingData.occupancy || '').toString(),
      room_type: bookingData.room_type || '',
      room_quantity: parseInt(bookingData.rooms) || 1,
      breakfast_status: bookingData.breakfast || '',
      total_amount: parseFloat(cleanMoneyString(bookingData.total_price)) || 0,
      commission_amount: parseFloat(cleanMoneyString(bookingData.commission)) || 0,
      transfer_amount: parseFloat(cleanMoneyString(bookingData.surcharge)) || 0,
      other_programs: bookingData.other_programs || '',
      net_amount: parseFloat(cleanMoneyString(bookingData.net_rate)) || 0,
      payment_status: bookingData.payment_status || '',
      notes: syncNotes,
      status: 'Pending',
      email_date: now,
      created_at: now,
      updated_at: now
    };

    if (checkIn) payload.check_in = checkIn;
    if (checkOut) payload.check_out = checkOut;

    // ✅ UPSERT: 1 API call duy nhất (thay vì SELECT + INSERT/UPDATE)
    // on_conflict=booking_code: Nếu trùng → merge/update đúng record.
    // Booking.com nhiều phòng dùng suffix _P1/_P2/_P3 nên không bị ghi đè nhau.
    var url = SUPABASE_CONFIG.URL + '/rest/v1/' + SUPABASE_CONFIG.TABLE;
    if (!allowDuplicateBookingCode) {
      url += '?on_conflict=booking_code';
    }

    var preferHeader = allowDuplicateBookingCode
      ? 'return=minimal'
      : 'resolution=merge-duplicates,return=minimal';

    var res = UrlFetchApp.fetch(url, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_CONFIG.API_KEY,
        'Authorization': 'Bearer ' + SUPABASE_CONFIG.API_KEY,
        'Content-Type': 'application/json',
        'Prefer': preferHeader
      },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    var code = res.getResponseCode();
    if (code >= 200 && code < 300) {
      if (ss) logToSheet(ss, '✅ Supabase SYNC: ' + supabaseBookingCode + ' (gốc: ' + bookingCode + ')');
    } else {
      if (ss) logToSheet(ss, '⚠️ Supabase SYNC ' + supabaseBookingCode + ' HTTP ' + code);
    }

  } catch (e) {
    if (ss) logToSheet(ss, '❌ Supabase sync lỗi (' + (bookingData.booking_id || '?') + '): ' + e.toString());
  }
}

/**
 * Sync trạng thái hủy lên Supabase
 * ✅ FIX: Dùng LIKE để match cả mã gốc lẫn mã có suffix _ngày
 * Ví dụ: bookingCode = "30092" → match "30092", "30092_2026-05-12", "30092_2026-05-13"...
 */
function syncCancellationToSupabase_(bookingCode, cancellationDate, ss) {
  try {
    if (!bookingCode) return;

    var payload = {
      status: 'Cancelled',
      updated_at: new Date().toISOString()
    };

    if (cancellationDate) {
      payload.cancellation_date = parseDateToISO_(cancellationDate) || new Date().toISOString();
    }

    // Dùng LIKE để match tất cả các dòng: "30092", "30092_2026-05-12", ...
    var likePattern = bookingCode + '*';
    var url = SUPABASE_CONFIG.URL + '/rest/v1/' + SUPABASE_CONFIG.TABLE
      + '?booking_code=like.' + encodeURIComponent(likePattern);

    var res = UrlFetchApp.fetch(url, {
      method: 'PATCH',
      headers: {
        'apikey': SUPABASE_CONFIG.API_KEY,
        'Authorization': 'Bearer ' + SUPABASE_CONFIG.API_KEY,
        'Content-Type': 'application/json',
        'Prefer': 'return=representation'
      },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    var code = res.getResponseCode();
    var body = res.getContentText();
    var updatedCount = 0;
    try { updatedCount = JSON.parse(body).length || 0; } catch(x) {}

    if (code >= 200 && code < 300) {
      if (ss) logToSheet(ss, '🚫 Supabase CANCEL: ' + bookingCode + ' (' + updatedCount + ' bản ghi đã hủy)');
    } else {
      if (ss) logToSheet(ss, '❌ Supabase CANCEL FAIL: ' + bookingCode + ' HTTP ' + code + ' - ' + body);
    }

  } catch (e) {
    if (ss) logToSheet(ss, '❌ Supabase cancel sync lỗi: ' + e.toString());
  }
}

// --- SUPABASE REST API HELPERS ---

function supabaseSelect_(bookingCode) {
  var url = SUPABASE_CONFIG.URL + '/rest/v1/' + SUPABASE_CONFIG.TABLE
    + '?booking_code=eq.' + encodeURIComponent(bookingCode)
    + '&select=id,booking_code,assigned_room,status,app_confirm_status'
    + '&limit=1';

  var res = UrlFetchApp.fetch(url, {
    method: 'GET',
    headers: {
      'apikey': SUPABASE_CONFIG.API_KEY,
      'Authorization': 'Bearer ' + SUPABASE_CONFIG.API_KEY
    },
    muteHttpExceptions: true
  });

  var data = JSON.parse(res.getContentText());
  return (data && data.length > 0) ? data[0] : null;
}

