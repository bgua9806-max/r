 */
function testStructuredAIFromLabel() {
  var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
  var resultSheet = getOrCreateTestResultSheet(ss);

  // Load platform config để phát hiện email hủy
  var platformConfigs = loadPlatformConfig(ss);

  var label = GmailApp.getUserLabelByName(CONFIG.TEST_LABEL_NAME);
  if (!label) {
    resultSheet.appendRow(["", "❌ ERROR", "Không tìm thấy Gmail label: " + CONFIG.TEST_LABEL_NAME]);
    return;
  }

  var threads = label.getThreads(0, CONFIG.TEST_BATCH_SIZE || 5);
  if (!threads || threads.length === 0) {
    resultSheet.appendRow(["", "⚠️ EMPTY", "Không có email nào trong label: " + CONFIG.TEST_LABEL_NAME]);
    return;
  }

  for (var i = 0; i < threads.length; i++) {
    var messages = threads[i].getMessages();

    for (var j = 0; j < messages.length; j++) {
      var message = messages[j];
      var subject = message.getSubject();
      var fromEmail = message.getFrom();

      try {
        // ═══════════════════════════════════════════════════════════════
        // ✅ KIỂM TRA EMAIL HỦY TRƯỚC (giống luồng chính)
        // ═══════════════════════════════════════════════════════════════
        if (isCancellationFromConfig(subject, fromEmail, platformConfigs)) {
          var cancelPlatform = detectCancellationPlatform(subject, fromEmail);
          var cancelBookingId = extractCancelBookingId(message, subject, cancelPlatform);
          var cancelDate = Utilities.formatDate(message.getDate(), Session.getScriptTimeZone(), "dd/MM/yyyy");

          // ✅ TEST MODE: cập nhật TẤT CẢ dòng cùng Mã BK.
          // Trip.com daily-rate split tạo nhiều dòng cùng booking ID, nên email hủy phải hủy toàn bộ các ngày.
          var updatedCancelRows = cancelBookingId ? updateAllRowsByBookingId_(resultSheet, cancelBookingId, "CANCEL", cancelDate, "Email hủy: " + subject) : 0;
          if (updatedCancelRows === 0) {
            // Nếu chưa có booking gốc trong sheet test, mới append dòng CANCEL để bạn biết email hủy đã được nhận diện.
            resultSheet.appendRow([
              message.getDate(),
              cancelPlatform,
              "",
              cancelBookingId || "KHÔNG TÌM THẤY ID",
              "", "", "", "", "", "",
              "", "", "", "", "", "", "",
              "Email hủy: " + subject,
              "CANCEL",
              "",
              cancelDate
            ]);
          }

          // ✅ Gửi trạng thái hủy lên Supabase database luôn
          if (cancelBookingId) {
            syncCancellationToSupabase_(cancelBookingId, cancelDate, ss);
          }
          continue;
        }

        // ═══════════════════════════════════════════════════════════════
        // 📋 XỬ LÝ BOOKING MỚI (giống luồng chính)
        // ═══════════════════════════════════════════════════════════════
        var plainText = getDeepCleanBody(message);
        var smartContext = getHeadAndTail(plainText);
        var platform = detectPlatform(smartContext, subject);
        var hardData = scanDataByPlatform(smartContext, platform);
        var aiInput = CONFIG.USE_STRUCTURED_AI_INPUT
          ? buildStructuredAIInput(message, smartContext, hardData, platform)
          : smartContext;

        var finalData = callOpenAI(aiInput, hardData, platform);

        // Override regex giống production
        if (hardData.total_price && hardData.total_price !== "0") finalData.total_price = hardData.total_price;
        if (hardData.net_rate && hardData.net_rate !== "0") finalData.net_rate = hardData.net_rate;
        if (hardData.commission && hardData.commission !== "0") finalData.commission = hardData.commission;
        if (hardData.surcharge && hardData.surcharge !== "0") finalData.surcharge = hardData.surcharge;
        if (hardData.other_programs && hardData.other_programs !== "0") finalData.other_programs = hardData.other_programs;
        if (hardData.payment_status) finalData.payment_status = hardData.payment_status;
        if (hardData.has_breakfast) finalData.breakfast = hardData.has_breakfast;

        // Làm sạch tiền giống production
        finalData.total_price = cleanMoneyString(finalData.total_price);
        finalData.net_rate = cleanMoneyString(finalData.net_rate);
        finalData.commission = cleanMoneyString(finalData.commission);
        finalData.surcharge = cleanMoneyString(finalData.surcharge);
        finalData.other_programs = cleanMoneyString(finalData.other_programs);

        // Format room type giống production
        var finalRoomType = finalData.room_type || "";
        if (platform !== "Traveloka" && finalRoomType) {
          var roomCodeMatch = finalRoomType.match(/(\d+G\s*\d+M\d+)/i);
          if (!roomCodeMatch) roomCodeMatch = finalRoomType.match(/\(([A-Z0-9]{3,})\)/i);
          if (roomCodeMatch) {
            var roomCode = roomCodeMatch[1].replace(/\s+/g, '').toUpperCase();
            finalRoomType = roomCode + ' (x' + (finalData.rooms || 1) + ')';
          }
        }

        // Trip.com guest name fix
        if (platform === "Trip.com" && finalData && finalData.guest_name) {
          finalData.guest_name = finalData.guest_name.replace(/\//g, " ").replace(/\s+/g, " ").trim();
        }

        var testRows = buildBookingRowsByPlatform_(message, finalData, finalRoomType, platform, plainText, "✅ TEST");
        for (var r = 0; r < testRows.length; r++) {
          var testRow = testRows[r];
          var bookingId = testRow[3] ? testRow[3].toString().trim() : "";
          var checkInKey = formatDateKey_(testRow[5]);
          var compositeKey = bookingId + "__" + checkInKey;
          if (bookingId && hasBookingDateKey_(resultSheet, compositeKey)) continue;
          resultSheet.appendRow(testRow);

          // ✅ Gửi lên Supabase database luôn
          if (bookingId) {
            var testBookingData = {
              booking_id: bookingId,
              platform: testRow[1] || platform,
              hotel_name: testRow[2] || '',
              guest_name: testRow[4] || '',
              check_in: testRow[5],
              check_out: testRow[6],
              room_type: testRow[7] || '',
