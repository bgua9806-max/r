// KHỞI TẠO THƯ MỤC DRIVE
// ============================================================================
function setupDriveFolders() {
  var ui = SpreadsheetApp.getUi();
  try {
    var rootFolder = DriveApp.getRootFolder();
    var mainName = "AI_Booking_PDFs";
    var pendingName = "1_Booking_Pending";
    var doneName = "2_Booking_Done";
    
    // Tìm hoặc tạo thư mục MẸ ở ngoài cùng
    var mainIter = rootFolder.getFoldersByName(mainName);
    var mainFolder = mainIter.hasNext() ? mainIter.next() : rootFolder.createFolder(mainName);
    
    // Tìm hoặc tạo thư mục CON ở bên trong thư mục MẸ
    var pendingIter = mainFolder.getFoldersByName(pendingName);
    var doneIter = mainFolder.getFoldersByName(doneName);
    
    var pendingFolder = pendingIter.hasNext() ? pendingIter.next() : mainFolder.createFolder(pendingName);
    var doneFolder = doneIter.hasNext() ? doneIter.next() : mainFolder.createFolder(doneName);
    
    var msg = "✅ Đã tạo cấu trúc thư mục thành công!\n" +
              "Tất cả nằm trong thư mục chính: " + mainName + " (trên Google Drive)\n\n" +
              "📌 Vui lòng copy 2 đoạn mã ID dưới đây dán vào dòng 53-54 trong Code:\n\n" +
              "ID Thư mục PENDING:\n" + pendingFolder.getId() + "\n\n" +
              "ID Thư mục DONE:\n" + doneFolder.getId();
              
    ui.alert("Thông báo", msg, ui.ButtonSet.OK);
    
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    if (ss) {
      logToSheet(ss, '✅ [SETUP] PENDING FOLDER ID: ' + pendingFolder.getId());
      logToSheet(ss, '✅ [SETUP] DONE FOLDER ID: ' + doneFolder.getId());
    }
  } catch (err) {
    ui.alert("❌ Lỗi", "Không thể tạo thư mục. Lỗi: " + err.toString(), ui.ButtonSet.OK);
  }
}

