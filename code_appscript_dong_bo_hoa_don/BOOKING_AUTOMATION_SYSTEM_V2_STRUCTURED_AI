function getDeepCleanBody(message) {
  var body = message.getBody();
  body = body.replace(/<style([\s\S]*?)<\/style>/gi, "").replace(/<script([\s\S]*?)<\/script>/gi, "");
  body = body.replace(/<\/td>/gi, " | ").replace(/<\/tr>/gi, "\n").replace(/<br\s*\/?>/gi, "\n").replace(/<\/p>/gi, "\n").replace(/<\/div>/gi, "\n");
  body = body.replace(/<[^>]+>/g, " ");
  return body.replace(/\s+/g, " ").trim();
}



function extractAirbnbStayDates_(text) {
  if (!text) return null;

  // Airbnb VI: "Nhận phòng Trả phòng ... Th 2, 4 thg 5   Th 4, 6 thg 5"
  // Lưu ý: "Th 2" / "Th 4" là thứ trong tuần, KHÔNG PHẢI ngày/tháng.
  var normalized = text.toString().replace(/\s+/g, " ").trim();
  var sectionMatch = normalized.match(/Nhận phòng\s+Trả phòng([\s\S]{0,300}?)(?:Khách|Mã xác nhận|KHÁCH|MÃ XÁC NHẬN)/i);
  var section = sectionMatch ? sectionMatch[1] : normalized;
  var dateRegex = /Th\s*\d\s*,\s*(\d{1,2})\s*thg\s*(\d{1,2})/gi;
  var dates = [];
  var match;

  while ((match = dateRegex.exec(section)) !== null) {
    dates.push({ day: parseInt(match[1], 10), month: parseInt(match[2], 10) });
    if (dates.length >= 2) break;
  }

  if (dates.length < 2) return null;

  var year = new Date().getFullYear();
  var checkIn = new Date(year, dates[0].month - 1, dates[0].day);
  var checkOut = new Date(year, dates[1].month - 1, dates[1].day);

  // Nếu checkout nhỏ hơn checkin thì booking qua năm sau.
  if (checkOut.getTime() < checkIn.getTime()) {
    checkOut = new Date(year + 1, dates[1].month - 1, dates[1].day);
  }

  return {
    check_in: Utilities.formatDate(checkIn, Session.getScriptTimeZone(), "yyyy-MM-dd"),
    check_out: Utilities.formatDate(checkOut, Session.getScriptTimeZone(), "yyyy-MM-dd")
  };
}

function parseDateToSheetFormat(dateStr) {
  if (!dateStr || dateStr.length < 10) return dateStr;
  try {
    var parts = dateStr.split("-");
    if (parts.length === 3) return new Date(parts[0], parts[1] - 1, parts[2]);
  } catch (e) {}
  return dateStr;
}



function cleanMoneyString(val) {
  if (!val) return 0;
  var str = val.toString().trim();
  // Loại bỏ .00 hoặc ,00 ở cuối (nếu có)
  str = str.replace(/[.,]00$/, '');
  // Chỉ giữ lại số và dấu trừ
  str = str.replace(/[^\d-]/g, '');
  var num = parseInt(str, 10);
  return isNaN(num) ? 0 : num;
}



