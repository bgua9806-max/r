}

function customExport(sheetName, dateStr) {
  try {
    var filterDate = parseDate(dateStr);
    if (!filterDate) {
      return { success: false, message: '❌ Ngày không hợp lệ. Định dạng: DD/MM/YYYY' };
    }
    
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName(sheetName);
    
    if (!sheet) {
      return { success: false, message: '❌ Không tìm thấy sheet: ' + sheetName };
    }
    
    if (sheetName === "ASM_VN") {
      var textColumns = ["Số giấy tờ", "Số điện thoại", "CMND/CCCD", "Số hộ chiếu", "Ngày, tháng, năm sinh", "Thời gian lưu trú (từ)", "Thời gian lưu trú (đến)"];
      var result = exportFilteredSheetToCSV(sheet, "ASM_VN", filterDate, "Thời gian lưu trú (từ)", textColumns);
    } else {
      var result = exportForeignGuestToCSV(sheet, "Danh_Sach_Khach_Nuoc_Ngoai", filterDate, "Ngày đến");
    }
    
    if (result.rowCount === 0) {
      return { 
        success: false, 
        message: '⚠️ Không có dữ liệu ngày ' + Utilities.formatDate(filterDate, "Asia/Ho_Chi_Minh", "dd/MM/yyyy") 
      };
    }
    
    return {
      success: true,
      base64Data: Utilities.base64Encode(result.blob.getBytes()),
      fileName: result.fileName,
      mimeType: result.blob.getContentType(),
      rowCount: result.rowCount
    };
    
  } catch (error) {
    return { success: false, message: '❌ Lỗi: ' + error.toString() };
  }
}

