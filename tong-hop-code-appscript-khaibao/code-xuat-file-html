<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Roboto', Arial, sans-serif;
      padding: 24px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100%;
    }
    
    .container {
      background: white;
      padding: 28px;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }
    
    h2 {
      color: #1a73e8;
      margin-bottom: 24px;
      text-align: center;
      font-size: 20px;
    }
    
    .form-group {
      margin-bottom: 18px;
    }
    
    label {
      display: block;
      margin-bottom: 8px;
      color: #333;
      font-weight: 500;
      font-size: 14px;
    }
    
    select, input[type="date"] {
      width: 100%;
      padding: 12px 14px;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 15px;
      font-family: 'Roboto', Arial, sans-serif;
      transition: border 0.3s;
      background: #fff;
      cursor: pointer;
    }
    
    select:focus, input[type="date"]:focus {
      outline: none;
      border-color: #1a73e8;
      box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.15);
    }

    input[type="date"] {
      color: #333;
    }

    input[type="date"]::-webkit-calendar-picker-indicator {
      cursor: pointer;
      padding: 4px;
      border-radius: 4px;
      background: #e8f0fe;
      transition: background 0.2s;
    }

    input[type="date"]::-webkit-calendar-picker-indicator:hover {
      background: #c6dbfc;
    }

    .date-display {
      margin-top: 6px;
      font-size: 13px;
      color: #1a73e8;
      font-weight: 500;
    }
    
    .btn-export {
      width: 100%;
      background: linear-gradient(135deg, #1a73e8 0%, #004ba0 100%);
      color: white;
      padding: 14px;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(26, 115, 232, 0.3);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-top: 8px;
    }
    
    .btn-export:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26, 115, 232, 0.4);
    }
    
    .btn-export:active {
      transform: translateY(0);
    }
    
    .btn-export:disabled {
      background: #ccc;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }
    
    .status {
      margin-top: 16px;
      padding: 14px;
      border-radius: 8px;
      text-align: center;
      font-weight: 500;
      display: none;
    }
    
    .status.success {
      background: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
    }
    
    .status.error {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }
    
    .loading {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid #f3f3f3;
      border-top: 3px solid #1a73e8;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-right: 10px;
      vertical-align: middle;
    }
    
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .hint {
      font-size: 12px;
      color: #888;
      margin-top: 4px;
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>🚀 Xuất File Báo Cáo Tùy Chỉnh</h2>
    
    <div class="form-group">
      <label for="sheetSelect">📋 Chọn Sheet:</label>
      <select id="sheetSelect">
        <option value="">Đang tải...</option>
      </select>
      <div class="hint">Mặc định: ASM_VN (Khách Việt Nam)</div>
    </div>
    
    <div class="form-group">
      <label for="dateInput">📅 Chọn Ngày:</label>
      <input type="date" id="dateInput">
      <div class="date-display" id="dateDisplay"></div>
      <div class="hint">Mặc định: Ngày hôm nay. Bấm vào lịch để chọn ngày khác.</div>
    </div>
    
    <button class="btn-export" onclick="exportFile()">
      📥 Xuất File & Tải Xuống
    </button>
    
    <div class="status" id="status"></div>
  </div>

  <script>
    window.onload = function() {
      // 1. Load danh sách sheets
      google.script.run
        .withSuccessHandler(function(sheets) {
          var select = document.getElementById('sheetSelect');
          select.innerHTML = '';
          
          sheets.forEach(function(sheet) {
            var option = document.createElement('option');
            option.value = sheet;
            option.textContent = sheet;
            
            // ✅ FIX: Mặc định chọn ASM_VN (Khách Việt Nam)
            if (sheet === 'ASM_VN') {
              option.selected = true;
            }
            
            select.appendChild(option);
          });
        })
        .withFailureHandler(function(error) {
          document.getElementById('sheetSelect').innerHTML = '<option>Lỗi tải sheets</option>';
        })
        .getSheetNames();
      
      // 2. Mặc định ngày = HÔM NAY
      setDateToToday();
    };

    function setDateToToday() {
      var today = new Date();
      var yyyy = today.getFullYear();
      var mm = String(today.getMonth() + 1).padStart(2, '0');
      var dd = String(today.getDate()).padStart(2, '0');
      document.getElementById('dateInput').value = yyyy + '-' + mm + '-' + dd;
      updateDateDisplay();
    }

    function updateDateDisplay() {
      var dateInput = document.getElementById('dateInput');
      var display = document.getElementById('dateDisplay');
      
      if (dateInput.value) {
        var parts = dateInput.value.split('-');
        display.textContent = '→ Ngày xuất: ' + parts[2] + '/' + parts[1] + '/' + parts[0];
      } else {
        display.textContent = '';
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      var dateInput = document.getElementById('dateInput');
      if (dateInput) {
        dateInput.addEventListener('change', updateDateDisplay);
      }
    });

    function getFormattedDate() {
      var dateInput = document.getElementById('dateInput').value;
      if (!dateInput) return '';
      var parts = dateInput.split('-');
      return parts[2] + '/' + parts[1] + '/' + parts[0];
    }
    
    function exportFile() {
      var sheetName = document.getElementById('sheetSelect').value;
      var dateStr = getFormattedDate();
      var statusDiv = document.getElementById('status');
      var btn = document.querySelector('.btn-export');
      
      if (!sheetName || !dateStr) {
        showStatus('error', '❌ Vui lòng chọn sheet và chọn ngày!');
        return;
      }
      
      btn.disabled = true;
      btn.innerHTML = '<span class="loading"></span>Đang xuất file...';
      statusDiv.style.display = 'none';
      
      google.script.run
        .withSuccessHandler(function(result) {
          btn.disabled = false;
          btn.innerHTML = '📥 Xuất File & Tải Xuống';
          
          if (result.success) {
            showStatus('success', '✅ Xuất thành công ' + result.rowCount + ' khách! Đang tải xuống...');
            downloadFile(result.base64Data, result.fileName, result.mimeType);
          } else {
            showStatus('error', result.message);
          }
        })
        .withFailureHandler(function(error) {
          btn.disabled = false;
          btn.innerHTML = '📥 Xuất File & Tải Xuống';
          showStatus('error', '❌ Lỗi: ' + error.message);
        })
        .customExport(sheetName, dateStr);
    }
    
    function showStatus(type, message) {
      var statusDiv = document.getElementById('status');
      statusDiv.className = 'status ' + type;
      statusDiv.textContent = message;
      statusDiv.style.display = 'block';
    }
    
    function downloadFile(base64Data, fileName, mimeType) {
      var byteCharacters = atob(base64Data);
      var byteNumbers = new Array(byteCharacters.length);
      for (var i = 0; i < byteCharacters.length; i++) {
        byteNumbers[i] = byteCharacters.charCodeAt(i);
      }
      var byteArray = new Uint8Array(byteNumbers);
      var blob = new Blob([byteArray], {type: mimeType});
      
      var link = document.createElement('a');
      link.href = window.URL.createObjectURL(blob);
      link.download = fileName;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      setTimeout(function() {
        google.script.host.close();
      }, 2000);
    }
  </script>
</body>
</html>